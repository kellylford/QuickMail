<Window x:Class="QuickMail.Views.MessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:QuickMail.ViewModels"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="{Binding WindowTitle}"
        Height="560" Width="720"
        MinHeight="300" MinWidth="480"
        WindowStartupLocation="Manual"
        d:DataContext="{d:DesignInstance Type=vm:MessageWindowViewModel}"
        Closing="OnClosing"
        PreviewKeyDown="OnPreviewKeyDown"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <DockPanel>
        <!-- Menu bar (Alt / F10 to open) -->
        <Menu DockPanel.Dock="Top" IsMainMenu="True">
            <MenuItem Header="{x:Static strings:Strings.Message_Menu_File}">
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_CloseWindow}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_CloseWindow_Name}"
                          Command="{Binding CloseCommand}"
                          InputGestureText="Ctrl+W"/>
            </MenuItem>
            <MenuItem Header="{x:Static strings:Strings.Message_Menu_Message}">
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_Reply}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_Reply_Name}"
                          Command="{Binding ReplyCommand}"
                          InputGestureText="Ctrl+R"/>
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_ReplyAll}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_ReplyAll_Name}"
                          Command="{Binding ReplyAllCommand}"
                          InputGestureText="Ctrl+Shift+R"/>
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_Forward}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_Forward_Name}"
                          Command="{Binding ForwardCommand}"
                          InputGestureText="Ctrl+F"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_Delete}"
                          AutomationProperties.Name="{x:Static strings:Strings.Common_Delete}"
                          Command="{Binding DeleteMessageCommand}"
                          InputGestureText="Delete"/>
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_MarkAsRead}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_MarkAsRead_Name}"
                          Command="{Binding MarkReadCommand}"
                          InputGestureText="Ctrl+Q"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_GrabAddresses}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_GrabAddresses_Name}"
                          Command="{Binding GrabAddressesCommand}"
                          InputGestureText="Ctrl+Shift+G"/>
            </MenuItem>
            <MenuItem Header="{x:Static strings:Strings.Message_Menu_Navigate}">
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_PreviousMessage}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_PreviousMessage_Name}"
                          Command="{Binding PreviousMessageCommand}"
                          InputGestureText="Alt+Left"/>
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_NextMessage}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_NextMessage_Name}"
                          Command="{Binding NextMessageCommand}"
                          InputGestureText="Alt+Right"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Message_Menu_MoveToMainWindow}"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_MoveToMainWindow_Name}"
                          Command="{Binding MoveToMainWindowCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar Band="1" BandIndex="1">
                <Button x:Name="PrevButton"
                        Content="{x:Static strings:Strings.Message_Toolbar_Previous}"
                        Command="{Binding PreviousMessageCommand}"
                        Padding="6,2"
                        ToolTip="{x:Static strings:Strings.Message_Toolbar_Previous_ToolTip}"
                        AutomationProperties.Name="{x:Static strings:Strings.Message_PreviousMessage_Name}"/>
                <Button x:Name="NextButton"
                        Content="{x:Static strings:Strings.Message_Toolbar_Next}"
                        Command="{Binding NextMessageCommand}"
                        Padding="6,2"
                        ToolTip="{x:Static strings:Strings.Message_Toolbar_Next_ToolTip}"
                        AutomationProperties.Name="{x:Static strings:Strings.Message_NextMessage_Name}"/>
                <Separator/>
                <Button Content="{x:Static strings:Strings.Message_Menu_Reply}"
                        Command="{Binding ReplyCommand}"
                        Padding="6,2"
                        ToolTip="{x:Static strings:Strings.Message_Toolbar_Reply_ToolTip}"
                        AutomationProperties.Name="{x:Static strings:Strings.Message_Reply_Name}"/>
                <Button Content="{x:Static strings:Strings.Message_Menu_ReplyAll}"
                        Command="{Binding ReplyAllCommand}"
                        Padding="6,2"
                        ToolTip="{x:Static strings:Strings.Message_Toolbar_ReplyAll_ToolTip}"
                        AutomationProperties.Name="{x:Static strings:Strings.Message_ReplyAll_Name}"/>
                <Button Content="{x:Static strings:Strings.Message_Menu_Forward}"
                        Command="{Binding ForwardCommand}"
                        Padding="6,2"
                        ToolTip="{x:Static strings:Strings.Message_Toolbar_Forward_ToolTip}"
                        AutomationProperties.Name="{x:Static strings:Strings.Message_Forward_Name}"/>
                <Separator/>
                <Button Content="{x:Static strings:Strings.Message_Menu_Delete}"
                        Command="{Binding DeleteMessageCommand}"
                        Padding="6,2"
                        ToolTip="{x:Static strings:Strings.Message_Toolbar_Delete_ToolTip}"
                        AutomationProperties.Name="{x:Static strings:Strings.Common_Delete}"/>
                <Separator/>
                <Button Content="{x:Static strings:Strings.Message_Menu_MoveToMainWindow}"
                        Command="{Binding MoveToMainWindowCommand}"
                        Padding="6,2"
                        AutomationProperties.Name="{x:Static strings:Strings.Message_MoveToMainWindowToolbar_Name}"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   AutomationProperties.Name="{x:Static strings:Strings.Message_Status_Name}">
            <StatusBarItem>
                <TextBlock Text="{Binding PositionText, Mode=OneWay}"
                           AutomationProperties.LiveSetting="Off"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Header fields -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource Theme.Border}"
                Padding="8,6,8,6">
            <StackPanel>
                <TextBox x:Name="SubjectField"
                         Text="{Binding MessageDetail.Subject, FallbackValue='', Mode=OneWay}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         BorderThickness="0" Background="Transparent"
                         FontWeight="SemiBold" TextWrapping="Wrap"
                         AutomationProperties.Name="{x:Static strings:Strings.Message_Subject_Name}"/>
                <TextBox x:Name="FromField"
                         Text="{Binding MessageDetail.From, FallbackValue='', Mode=OneWay}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         BorderThickness="0" Background="Transparent"
                         Margin="0,2,0,0"
                         AutomationProperties.Name="{x:Static strings:Strings.Message_From_Name}"/>
                <TextBox x:Name="ToField"
                         Text="{Binding MessageDetail.To, FallbackValue='', Mode=OneWay}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         BorderThickness="0" Background="Transparent"
                         AutomationProperties.Name="{x:Static strings:Strings.Message_To_Name}"/>
                <TextBox x:Name="CcField"
                         Text="{Binding MessageDetail.Cc, FallbackValue='', Mode=OneWay}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         BorderThickness="0" Background="Transparent"
                         AutomationProperties.Name="{x:Static strings:Strings.Message_Cc_Name}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MessageDetail.Cc}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding MessageDetail.Cc}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <TextBox x:Name="DateField"
                         Text="{Binding MessageDetail.Date, StringFormat='{}{0:f}', FallbackValue='', Mode=OneWay}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         BorderThickness="0" Background="Transparent"
                         AutomationProperties.Name="{x:Static strings:Strings.Message_Date_Name}"/>

                <!-- Attachments -->
                <ListBox x:Name="AttachmentList"
                         ItemsSource="{Binding MessageDetail.Attachments}"
                         SelectionMode="Single"
                         BorderThickness="0"
                         Margin="0,4,0,0"
                         Visibility="{Binding MessageDetail.HasAttachments,
                                      Converter={StaticResource BoolToVisibilityConverter},
                                      FallbackValue=Collapsed}"
                         KeyboardNavigation.TabNavigation="Once"
                         KeyboardNavigation.DirectionalNavigation="Contained"
                         AutomationProperties.Name="{x:Static strings:Strings.Message_Attachments_Name}"
                         PreviewKeyDown="AttachmentList_PreviewKeyDown"
                         GotKeyboardFocus="AttachmentList_GotKeyboardFocus">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}" ToolTip="{Binding FileSizeDisplay}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{x:Static strings:Strings.Message_Menu_SaveAttachment}"
                                      Command="{Binding PlacementTarget.DataContext.SaveAttachmentCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="{x:Static strings:Strings.Message_Menu_SaveAllAttachments}"
                                      Command="{Binding PlacementTarget.DataContext.SaveAllAttachmentsCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="{x:Static strings:Strings.Message_Menu_OpenAttachment}"
                                      Command="{Binding PlacementTarget.DataContext.OpenAttachmentCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Message body + loading overlay -->
        <Grid>
            <wv2:WebView2 x:Name="MessageBody"
                          AutomationProperties.Name="{x:Static strings:Strings.Message_Body_Name}"
                          KeyboardNavigation.IsTabStop="True"
                          GotKeyboardFocus="MessageBody_GotKeyboardFocus"/>
            <Border Background="{DynamicResource Theme.WindowBackground}"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    IsHitTestVisible="False">
                <TextBlock Text="{x:Static strings:Strings.Message_Loading}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource Theme.FontSizeLarge}"
                           Foreground="{DynamicResource Theme.TextSecondary}"
                           AutomationProperties.LiveSetting="Polite"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
