<Window x:Class="QuickMail.Views.GroupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Group Manager"
        Height="520" Width="760"
        MinHeight="380" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        AutomationProperties.Name="Group Manager"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: groups list -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionLabel}" Text="Groups"/>
                <Button DockPanel.Dock="Bottom"
                        Content="_New group"
                        Command="{Binding CreateGroupCommand}"
                        AutomationProperties.Name="New group"
                        Margin="0,4,0,0"
                        TabIndex="20"/>
                <TextBox DockPanel.Dock="Bottom"
                         x:Name="NewGroupNameBox"
                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="New group name"
                         Margin="0,4,0,0"
                         TabIndex="19"
                         PreviewKeyDown="NewGroupNameBox_PreviewKeyDown"/>
                <ListBox x:Name="GroupsList"
                         ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                         DisplayMemberPath="Display"
                         AutomationProperties.Name="Groups"
                         TabIndex="10"
                         KeyboardNavigation.TabNavigation="Once"
                         PreviewKeyDown="GroupsList_PreviewKeyDown"/>
            </DockPanel>

            <!-- Right: members + add-member picker -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" IsTabStop="False"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Members of selected group -->
                <TextBlock Grid.Row="0" Style="{StaticResource SectionLabel}"
                           Text="{Binding SelectedGroupName, StringFormat='Members of {0}'}"/>
                <ListView Grid.Row="1"
                          x:Name="MembersList"
                          ItemsSource="{Binding GroupMembers}"
                          AutomationProperties.Name="Group members"
                          TabIndex="11"
                          KeyboardNavigation.TabNavigation="Once"
                          PreviewKeyDown="MembersList_PreviewKeyDown">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="AutomationProperties.Name" Value="{Binding Display}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name"  Width="180" DisplayMemberBinding="{Binding DisplayName}"/>
                            <GridViewColumn Header="Email" Width="240" DisplayMemberBinding="{Binding EmailAddress}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Add member picker -->
                <TextBlock Grid.Row="2" Style="{StaticResource SectionLabel}" Text="Add members"/>
                <DockPanel Grid.Row="3">
                    <TextBox DockPanel.Dock="Top"
                             x:Name="CandidateSearchBox"
                             Text="{Binding CandidateSearch, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Search contacts to add"
                             Margin="0,0,0,4"
                             TabIndex="12"/>
                    <ListView x:Name="CandidatesList"
                              ItemsSource="{Binding ContactCandidates}"
                              AutomationProperties.Name="Contact candidates"
                              TabIndex="13"
                              KeyboardNavigation.TabNavigation="Once"
                              PreviewKeyDown="CandidatesList_PreviewKeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="AutomationProperties.Name" Value="{Binding Display}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name"  Width="180" DisplayMemberBinding="{Binding DisplayName}"/>
                                <GridViewColumn Header="Email" Width="240" DisplayMemberBinding="{Binding EmailAddress}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RenameButton"
                    Content="_Rename"
                    Command="{Binding RenameSelectedCommand}"
                    IsEnabled="{Binding HasSelectedGroup}"
                    AutomationProperties.Name="Rename group"
                    MinWidth="80" Margin="0,0,6,0" TabIndex="21"/>
            <Button x:Name="DeleteButton"
                    Content="_Delete"
                    Command="{Binding DeleteSelectedCommand}"
                    IsEnabled="{Binding HasSelectedGroup}"
                    AutomationProperties.Name="Delete group"
                    MinWidth="80" Margin="0,0,12,0" TabIndex="22"/>
            <Button Content="Close"
                    IsCancel="True"
                    AutomationProperties.Name="Close group manager"
                    MinWidth="80" TabIndex="23"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
