<Window x:Class="QuickMail.Views.AccountManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{x:Static strings:Strings.AccountManager_Title}"
        Height="660" Width="720"
        MinHeight="500" MinWidth="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" MinWidth="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Account list -->
        <DockPanel Grid.Column="0" Grid.Row="0">
            <TextBlock DockPanel.Dock="Top" Text="{x:Static strings:Strings.AccountManager_AccountsHeading}" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="{x:Static strings:Strings.AccountManager_NewButton}"
                        Click="NewButton_Click"
                        AutomationProperties.Name="{x:Static strings:Strings.AccountManager_AddNewAccountName}"
                        MinWidth="60" Margin="0,0,4,0"/>
                <Button Content="{x:Static strings:Strings.AccountManager_DeleteButton}"
                        Command="{Binding DeleteAccountCommand}"
                        AutomationProperties.Name="{x:Static strings:Strings.AccountManager_DeleteSelectedAccountName}"
                        MinWidth="60" Margin="0,0,4,0"/>
                <Button Content="{x:Static strings:Strings.AccountManager_SetDefaultButton}"
                        Command="{Binding SetDefaultCommand}"
                        CommandParameter="{Binding SelectedAccount}"
                        AutomationProperties.Name="{x:Static strings:Strings.AccountManager_SetSelectedAccountAsDefaultName}"
                        MinWidth="75"/>
            </StackPanel>
            <ListBox x:Name="AccountListBox"
                     ItemsSource="{Binding Accounts}"
                     SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                     AutomationProperties.Name="{x:Static strings:Strings.AccountManager_AccountListName}"
                     TextSearch.TextPath="AccountLabelWithDefault"
                     BorderThickness="1">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="AutomationProperties.Name" Value="{Binding AccountLabelWithDefault}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding AccountLabel}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static strings:Strings.AccountManager_DefaultSuffix}" FontStyle="Italic" Foreground="{DynamicResource Theme.Accent}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Edit form -->
        <ScrollViewer Grid.Column="1" Grid.Row="0" Margin="10,0,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel IsEnabled="{Binding IsEditing}">

                <TextBlock Text="{x:Static strings:Strings.AccountManager_AccountSettingsHeading}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Account Name -->
                <Label x:Name="LblAccountName" Content="{x:Static strings:Strings.AccountManager_AccountNameLabel}" Target="{Binding ElementName=AccountNameBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="AccountNameBox"
                         Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblAccountName}"
                         TabIndex="0"/>

                <!-- Sender Display Name -->
                <Label x:Name="LblDisplayName" Content="{x:Static strings:Strings.AccountManager_SenderDisplayNameLabel}" Target="{Binding ElementName=DisplayNameBox}" Padding="0" Margin="0,8,0,2"/>
                <TextBox x:Name="DisplayNameBox"
                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblDisplayName}"
                         TabIndex="1"/>

                <!-- Username -->
                <Label x:Name="LblUsername" Content="{x:Static strings:Strings.AccountManager_EmailUsernameLabel}" Target="{Binding ElementName=UsernameBox}" Padding="0" Margin="0,8,0,2"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblUsername}"
                         TabIndex="2"/>

                <!-- Authentication type — hidden for Microsoft 365 (Graph), which is always OAuth. -->
                <StackPanel Visibility="{Binding IsImapBackend, Converter={StaticResource BoolToVisibility}}">
                    <Label x:Name="LblAuthType" Content="{x:Static strings:Strings.AccountManager_AuthenticationLabel}" Target="{Binding ElementName=AuthTypeCombo}" Padding="0" Margin="0,8,0,2"/>
                    <ComboBox x:Name="AuthTypeCombo"
                              SelectedIndex="{Binding AuthTypeIndex, Mode=TwoWay}"
                              AutomationProperties.LabeledBy="{Binding ElementName=LblAuthType}"
                              AutomationProperties.Name="{x:Static strings:Strings.AccountManager_AuthenticationMethodName}"
                              TabIndex="3">
                        <ComboBoxItem Content="{x:Static strings:Strings.AccountManager_AuthOptionPassword}"/>
                        <ComboBoxItem Content="{x:Static strings:Strings.AccountManager_AuthOptionMicrosoftOAuth}"/>
                        <ComboBoxItem Content="{x:Static strings:Strings.AccountManager_AuthOptionGoogleOAuth}" Visibility="{Binding ShowGoogleAuthOption, Converter={StaticResource BoolToVisibility}}"/>
                    </ComboBox>
                </StackPanel>

                <!-- Password panel -->
                <StackPanel Visibility="{Binding IsPasswordAuth, Converter={StaticResource BoolToVisibility}}">
                    <Label x:Name="LblPassword" Content="{x:Static strings:Strings.AccountManager_PasswordLabel}" Target="{Binding ElementName=PasswordBox}" Padding="0" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="PasswordBox"
                                 AutomationProperties.LabeledBy="{Binding ElementName=LblPassword}"
                                 AutomationProperties.HelpText="{x:Static strings:Strings.AccountManager_PasswordHelpText}"
                                 TabIndex="5"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                    <!-- iCloud app-specific password hint -->
                    <Border Visibility="{Binding IsICloudAccount, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource Theme.WarningBackground}"
                            BorderBrush="{DynamicResource Theme.Warning}"
                            BorderThickness="1"
                            Padding="8,6"
                            Margin="0,6,0,0">
                        <TextBlock TextWrapping="Wrap"
                                   AutomationProperties.Name="{x:Static strings:Strings.AccountManager_ICloudPasswordHintName}">
                            <Run FontWeight="SemiBold" Text="{x:Static strings:Strings.AccountManager_ICloudHintBold}"/>
                            <Run Text="{x:Static strings:Strings.AccountManager_ICloudHintBody}"/>
                            <Run FontWeight="SemiBold" Text="{x:Static strings:Strings.AccountManager_ICloudHintUrl}"/>
                            <Run Text="{x:Static strings:Strings.AccountManager_ICloudHintTail}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Microsoft OAuth2 sign-in panel -->
                <StackPanel Visibility="{Binding IsOAuth2, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,4,0,0">
                    <Button Content="{x:Static strings:Strings.AccountManager_SignInMicrosoftButton}"
                            Command="{Binding SignInMicrosoftCommand}"
                            AutomationProperties.Name="{x:Static strings:Strings.AccountManager_SignInMicrosoftName}"
                            HorizontalAlignment="Left" MinWidth="200" TabIndex="5"/>
                </StackPanel>

                <!-- Google OAuth sign-in panel -->
                <StackPanel Visibility="{Binding IsGoogleOAuth, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,4,0,0">
                    <Button Content="{x:Static strings:Strings.AccountManager_SignInGoogleButton}"
                            Command="{Binding SignInGoogleCommand}"
                            AutomationProperties.Name="{x:Static strings:Strings.AccountManager_SignInGoogleName}"
                            HorizontalAlignment="Left" MinWidth="200" TabIndex="5"/>
                </StackPanel>

                <!-- IMAP + SMTP server settings — hidden for Microsoft 365 (Graph) accounts. -->
                <StackPanel Visibility="{Binding IsImapBackend, Converter={StaticResource BoolToVisibility}}">
                <Separator Margin="0,12"/>

                <!-- IMAP Settings -->
                <TextBlock Text="{x:Static strings:Strings.AccountManager_IncomingMailImapHeading}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <Label x:Name="LblImapHost" Content="{x:Static strings:Strings.AccountManager_ImapHostLabel}" Target="{Binding ElementName=ImapHostBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="ImapHostBox"
                         Text="{Binding ImapHost, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblImapHost}"
                         TabIndex="4"/>

                <Label x:Name="LblImapPort" Content="{x:Static strings:Strings.AccountManager_ImapPortLabel}" Target="{Binding ElementName=ImapPortBox}" Padding="0" Margin="0,6,0,2"/>
                <TextBox x:Name="ImapPortBox"
                         Text="{Binding ImapPort, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblImapPort}"
                         TabIndex="4"/>

                <CheckBox Content="{x:Static strings:Strings.AccountManager_ImapUseSslCheckbox}"
                          IsChecked="{Binding ImapUseSsl}"
                          AutomationProperties.Name="{x:Static strings:Strings.AccountManager_ImapUseSslName}"
                          Margin="0,6" TabIndex="5"/>

                <CheckBox Content="{x:Static strings:Strings.AccountManager_ImapAcceptInvalidCertCheckbox}"
                          IsChecked="{Binding ImapAcceptInvalidCert}"
                          AutomationProperties.Name="{x:Static strings:Strings.AccountManager_ImapAcceptInvalidCertName}"
                          Margin="0,0,0,6" TabIndex="6"/>

                <Separator Margin="0,6"/>

                <!-- SMTP Settings -->
                <TextBlock Text="{x:Static strings:Strings.AccountManager_OutgoingMailSmtpHeading}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <Label x:Name="LblSmtpHost" Content="{x:Static strings:Strings.AccountManager_SmtpHostLabel}" Target="{Binding ElementName=SmtpHostBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="SmtpHostBox"
                         Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblSmtpHost}"
                         TabIndex="7"/>

                <Label x:Name="LblSmtpPort" Content="{x:Static strings:Strings.AccountManager_SmtpPortLabel}" Target="{Binding ElementName=SmtpPortBox}" Padding="0" Margin="0,6,0,2"/>
                <TextBox x:Name="SmtpPortBox"
                         Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblSmtpPort}"
                         TabIndex="8"/>

                <CheckBox Content="{x:Static strings:Strings.AccountManager_SmtpImplicitSslCheckbox}"
                          IsChecked="{Binding SmtpUseSsl}"
                          AutomationProperties.Name="{x:Static strings:Strings.AccountManager_SmtpImplicitSslName}"
                          Margin="0,6" TabIndex="9"/>

                <CheckBox Content="{x:Static strings:Strings.AccountManager_SmtpAcceptInvalidCertCheckbox}"
                          IsChecked="{Binding SmtpAcceptInvalidCert}"
                          AutomationProperties.Name="{x:Static strings:Strings.AccountManager_SmtpAcceptInvalidCertName}"
                          Margin="0,0,0,6" TabIndex="10"/>
                </StackPanel>

                <Separator Margin="0,6"/>

                <!-- Signature -->
                <TextBlock Text="{x:Static strings:Strings.AccountManager_EmailSignatureHeading}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Label x:Name="LblSignature" Content="{x:Static strings:Strings.AccountManager_SignatureLabel}" Target="{Binding ElementName=SignatureBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="SignatureBox"
                         Text="{Binding Signature, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblSignature}"
                         AutomationProperties.HelpText="{x:Static strings:Strings.AccountManager_SignatureHelpText}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         VerticalScrollBarVisibility="Auto"
                         TabIndex="11"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <DockPanel Grid.Column="1" Grid.Row="1" Margin="10,8,0,0">
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.AccountManager_CloseButton}"
                    Click="CloseButton_Click"
                    IsCancel="True"
                    AutomationProperties.Name="{x:Static strings:Strings.AccountManager_CloseAccountManagerName}"
                    MinWidth="80" Margin="6,0,0,0"/>
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.AccountManager_TestConnectionButton}"
                    Command="{Binding TestConnectionCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.AccountManager_TestImapConnectionName}"
                    Visibility="{Binding IsImapBackend, Converter={StaticResource BoolToVisibility}}"
                    MinWidth="120" Margin="6,0,0,0"/>
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.AccountManager_SaveButton}"
                    Command="{Binding SaveAccountCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.AccountManager_SaveAccountSettingsName}"
                    IsDefault="True"
                    MinWidth="80"/>
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding StatusText}"
                       AutomationProperties.Name="{x:Static strings:Strings.AccountManager_StatusName}"
                       Foreground="{DynamicResource Theme.Accent}"/>
        </DockPanel>
    </Grid>
</Window>
