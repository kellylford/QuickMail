<Window x:Class="QuickMail.Views.TemplatePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        Title="{x:Static strings:Strings.TemplatePicker_Title}"
        Height="380" Width="420"
        MinHeight="220" MinWidth="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <DockPanel Margin="10">

        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,8"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.Name="{x:Static strings:Strings.TemplatePicker_SearchName}"
                 PreviewKeyDown="SearchBox_PreviewKeyDown"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="InsertButton"
                    Content="{x:Static strings:Strings.TemplatePicker_InsertButtonContent}"
                    IsDefault="True"
                    MinWidth="75"
                    Margin="0,0,6,0"
                    Click="InsertButton_Click"
                    AutomationProperties.Name="{x:Static strings:Strings.TemplatePicker_InsertButtonName}"/>
            <Button Content="{x:Static strings:Strings.TemplatePicker_CancelButtonContent}"
                    IsCancel="True"
                    MinWidth="75"
                    AutomationProperties.Name="{x:Static strings:Strings.TemplatePicker_CancelButtonName}"/>
        </StackPanel>

        <ListBox x:Name="TemplateListBox"
                 ItemsSource="{Binding Templates}"
                 SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                 AutomationProperties.Name="{x:Static strings:Strings.TemplatePicker_TemplatesListName}"
                 DisplayMemberPath="Title"
                 BorderThickness="1"
                 KeyboardNavigation.TabNavigation="Once"
                 PreviewKeyDown="TemplateListBox_PreviewKeyDown"
                 MouseDoubleClick="TemplateListBox_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="AutomationProperties.Name" Value="{Binding Title}"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

    </DockPanel>
</Window>
