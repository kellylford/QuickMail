<Window x:Class="QuickMail.Views.FormattingListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        Title="{x:Static strings:Strings.FormattingList_Title}"
        SizeToContent="WidthAndHeight"
        MaxHeight="400"
        MinWidth="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">
    <DockPanel Margin="10">
        <Button DockPanel.Dock="Bottom"
                Content="{x:Static strings:Strings.FormattingList_Close}"
                IsCancel="True"
                IsDefault="True"
                HorizontalAlignment="Right"
                MinWidth="80"
                Margin="0,8,0,0"/>
        <!-- One row per formatting fact (e.g. "Heading 2", "Bold on"). The user
             arrows through entries at their own pace; Escape or Enter closes. -->
        <ListBox x:Name="FormattingList"
                 AutomationProperties.Name="{x:Static strings:Strings.FormattingList_Formatting}"
                 MinHeight="120"
                 KeyboardNavigation.DirectionalNavigation="Contained"/>
    </DockPanel>
</Window>
