<Window x:Class="QuickMail.Views.ForwardAttachmentDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Include Attachments"
        AutomationProperties.Name="Include Attachments"
        Height="320" Width="440"
        MinHeight="200" MinWidth="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0"
                    x:Name="ButtonPanel">
            <Button x:Name="ForwardButton"
                    Content="_Forward"
                    IsDefault="True"
                    MinWidth="80"
                    Margin="0,0,6,0"
                    Command="{Binding IncludeSelectedCommand}"/>
            <Button x:Name="CancelButton"
                    Content="_Cancel"
                    IsCancel="True"
                    MinWidth="75"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="AttachmentList"
                          ItemsSource="{Binding Items}"
                          Focusable="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel KeyboardNavigation.TabNavigation="Once"
                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                  Content="{Binding DisplayLabel}"
                                  AutomationProperties.Name="{Binding AutomationLabel}"
                                  Margin="2,4,2,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
