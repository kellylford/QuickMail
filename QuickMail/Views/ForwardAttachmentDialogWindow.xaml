<Window x:Class="QuickMail.Views.ForwardAttachmentDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Include Attachments"
        AutomationProperties.Name="Include Attachments"
        Height="320" Width="440"
        MinHeight="200" MinWidth="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- List is first in XAML → first Tab stop. Arrow keys navigate within. -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      Focusable="False" Margin="0,0,0,10">
            <ItemsControl x:Name="AttachmentList"
                          ItemsSource="{Binding Items}"
                          Focusable="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel KeyboardNavigation.TabNavigation="Once"
                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                  Content="{Binding DisplayLabel}"
                                  AutomationProperties.Name="{Binding AutomationLabel}"
                                  Margin="2,4,2,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Buttons second in XAML → Tab from list lands here, then Cancel. -->
        <StackPanel Grid.Row="1" x:Name="ButtonPanel"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ForwardButton"
                    Content="_Forward"
                    IsDefault="True"
                    MinWidth="80"
                    Margin="0,0,6,0"
                    Command="{Binding IncludeSelectedCommand}"/>
            <Button x:Name="CancelButton"
                    Content="_Cancel"
                    IsCancel="True"
                    MinWidth="75"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>

    </Grid>
</Window>
