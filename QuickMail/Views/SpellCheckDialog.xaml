<Window x:Class="QuickMail.Views.SpellCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Spelling"
        Height="380" Width="560"
        MinHeight="320" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left column: context, change-to, suggestions -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Content="_Not in dictionary:"
                   Target="{Binding ElementName=ContextBox}"
                   Padding="0,0,0,2"/>
            <TextBox Grid.Row="1"
                     x:Name="ContextBox"
                     Text="{Binding ContextLine, Mode=OneWay}"
                     AutomationProperties.Name="Not in dictionary"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Height="56"
                     Margin="0,0,0,8"/>

            <Label Grid.Row="2" Content="Change _to:"
                   Target="{Binding ElementName=ChangeToBox}"
                   Padding="0,0,0,2"/>
            <TextBox Grid.Row="3"
                     x:Name="ChangeToBox"
                     Text="{Binding ChangeToText, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Change to"
                     Margin="0,0,0,8"/>

            <Label Grid.Row="4" Content="_Suggestions:"
                   Target="{Binding ElementName=SuggestionsList}"
                   Padding="0,0,0,2"/>
            <ListBox Grid.Row="5"
                     x:Name="SuggestionsList"
                     ItemsSource="{Binding Suggestions}"
                     SelectedItem="{Binding SelectedSuggestion}"
                     AutomationProperties.Name="Suggestions"
                     KeyboardNavigation.TabNavigation="Once"
                     KeyboardNavigation.DirectionalNavigation="Contained"/>
        </Grid>

        <!-- Right column: the classic verb buttons -->
        <StackPanel Grid.Column="1" VerticalAlignment="Top">
            <StackPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="MinWidth" Value="130"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="Padding" Value="8,3"/>
                </Style>
            </StackPanel.Resources>

            <Button x:Name="ChangeButton" Content="_Change" IsDefault="True" Click="Change_Click"/>
            <Button Content="Change Al_l" Click="ChangeAll_Click"/>
            <Separator Margin="0,2,0,8"/>
            <Button Content="_Ignore" Click="Ignore_Click"/>
            <Button Content="I_gnore All" Click="IgnoreAll_Click"/>
            <Separator Margin="0,2,0,8"/>
            <Button Content="_Add to Dictionary" Click="AddToDictionary_Click"/>
            <Button Content="_Read in Context" Click="ReadContext_Click"/>
            <Separator Margin="0,2,0,8"/>
            <Button Content="Cl_ose" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
