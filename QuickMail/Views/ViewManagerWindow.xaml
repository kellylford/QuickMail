<Window x:Class="QuickMail.Views.ViewManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{x:Static strings:Strings.ViewManager_Title}"
        Height="520" Width="720"
        MinHeight="420" MinWidth="580"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        AutomationProperties.Name="{x:Static strings:Strings.ViewManager_Title}"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextSecondary}"/>
            <Setter Property="FontSize" Value="{DynamicResource Theme.FontSizeSmall}"/>
        </Style>
        <Style x:Key="ReadonlyField" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- Current state strip -->
            <RowDefinition Height="Auto"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Bottom buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Current state strip ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource Theme.InfoBackground}" BorderBrush="{DynamicResource Theme.Info}"
                BorderThickness="1" CornerRadius="3" Padding="10,7" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{x:Static strings:Strings.ViewManager_CurrentStateLabel}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentStateSummary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- ── Two-panel main area ─────────────────────────────────────────── -->
        <Grid Grid.Row="1" x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListColumn"     Width="210" MinWidth="150"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: saved views list -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionLabel}"
                           Text="{x:Static strings:Strings.ViewManager_SavedViewsHeading}" Margin="0,0,0,4"/>
                <ListBox x:Name="ViewsList"
                         ItemsSource="{Binding SavedViews}"
                         SelectedItem="{Binding SelectedView, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SavedViewsHeading}"
                         KeyboardNavigation.TabNavigation="Once"/>
            </DockPanel>

            <!-- Separator -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          IsTabStop="False"/>

            <!-- Right: details / edit panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,0,0,0">

                    <!-- ── Empty state: nothing selected ─────────────────────────── -->
                    <TextBlock Text="{x:Static strings:Strings.ViewManager_EmptyStateHint}"
                               Foreground="{DynamicResource Theme.TextSecondary}" Margin="0,8,0,0"
                               Visibility="{Binding HasNoSelectedView, Converter={StaticResource BoolToVis}}"/>
                    <Button x:Name="CreateNewViewButton"
                            Content="{x:Static strings:Strings.ViewManager_CreateNewViewFromCurrentState}"
                            Command="{Binding SaveAsNewCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            AutomationProperties.Name="{x:Static strings:Strings.ViewManager_CreateNewViewFromCurrentState}"
                            Visibility="{Binding HasNoSelectedView, Converter={StaticResource BoolToVis}}"/>

                    <!-- ── Read-only state: view selected, not editing ────────────── -->

                    <!-- View name as a heading -->
                    <TextBlock Text="{Binding SelectedView.Name}"
                               FontWeight="SemiBold" FontSize="{DynamicResource Theme.FontSizeLarge}"
                               Margin="0,4,0,8"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static strings:Strings.ViewManager_KeyboardShortcutLabel}"
                               Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding EditHotkey}"
                               Margin="0,0,0,6"
                               Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static strings:Strings.ViewManager_SavedFoldersLabel}"
                               Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}"/>
                    <TextBox Style="{StaticResource ReadonlyField}"
                             Text="{Binding SelectedFoldersSummary, Mode=OneWay}"
                             AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SavedFoldersLabel}"
                             Margin="0,0,0,6"
                             Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static strings:Strings.ViewManager_SavedSettingsLabel}"
                               Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}"/>
                    <TextBox Style="{StaticResource ReadonlyField}"
                             Text="{Binding SelectedModeSummary, Mode=OneWay}"
                             AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SavedViewSettingsName}"
                             Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}"/>

                    <!-- Edit + Delete action buttons -->
                    <StackPanel x:Name="ReadOnlyActionsPanel"
                                Orientation="Horizontal" Margin="0,14,0,0"
                                Visibility="{Binding ShowReadOnly, Converter={StaticResource BoolToVis}}">
                        <Button Content="{x:Static strings:Strings.ViewManager_ApplyViewButton}"
                                Command="{Binding ApplySelectedViewCommand}"
                                MinWidth="90" Margin="0,0,8,0"
                                ToolTip="{x:Static strings:Strings.ViewManager_ApplyViewToolTip}"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_ApplySelectedViewName}"/>
                        <Button Content="{x:Static strings:Strings.ViewManager_EditButton}"
                                Command="{Binding StartEditCommand}"
                                MinWidth="70" Margin="0,0,8,0"
                                ToolTip="{x:Static strings:Strings.ViewManager_EditToolTip}"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_EditSelectedViewName}"/>
                        <Button Content="{x:Static strings:Strings.ViewManager_DeleteButton}"
                                Command="{Binding DeleteCommand}"
                                MinWidth="70" Margin="0,0,8,0"
                                ToolTip="{x:Static strings:Strings.ViewManager_DeleteToolTip}"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_DeleteSelectedViewName}"/>
                        <Button Content="{x:Static strings:Strings.ViewManager_SaveAsNewButton}"
                                Command="{Binding SaveAsNewCommand}"
                                MinWidth="100"
                                ToolTip="{x:Static strings:Strings.ViewManager_SaveAsNewToolTip}"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SaveCurrentStateAsNewViewName}"/>
                    </StackPanel>

                    <!-- ── Edit state: view selected and editing ──────────────────── -->

                    <!-- Keyboard Shortcut (first focus target) -->
                    <TextBlock Style="{StaticResource SectionLabel}" Text="{x:Static strings:Strings.ViewManager_KeyboardShortcutLabel}"
                               Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>
                    <Grid Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EditHotkey, Mode=OneWay}"
                                 IsReadOnly="True" IsTabStop="False"
                                 Background="{DynamicResource Theme.SurfaceBackground}"
                                 AutomationProperties.Name="{x:Static strings:Strings.ViewManager_AssignedShortcutName}"
                                 Margin="0,0,4,0"/>
                        <Button x:Name="SetHotkeyButton"
                                Grid.Column="1"
                                Content="{x:Static strings:Strings.ViewManager_SetButton}"
                                Command="{Binding RequestSetHotkeyCommand}"
                                MinWidth="60" Margin="0,0,4,0"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SetKeyboardShortcutName}"/>
                        <Button Grid.Column="2"
                                Content="{x:Static strings:Strings.ViewManager_ClearButton}"
                                Command="{Binding ClearHotkeyCommand}"
                                MinWidth="60"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_ClearKeyboardShortcutName}"/>
                    </Grid>
                    <TextBlock Text="{x:Static strings:Strings.ViewManager_KeyboardShortcutHint}"
                               FontSize="{DynamicResource Theme.FontSizeSmall}" Foreground="{DynamicResource Theme.TextSecondary}" Margin="0,3,0,0"
                               Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>

                    <!-- Day Limit -->
                    <TextBlock Style="{StaticResource SectionLabel}" Text="{x:Static strings:Strings.ViewManager_DayLimitHeading}"
                               Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>
                    <CheckBox Content="{x:Static strings:Strings.ViewManager_ShowAllMessagesCheckbox}"
                              IsChecked="{Binding EditUnlimitedDays}"
                              AutomationProperties.Name="{x:Static strings:Strings.ViewManager_ShowAllMessagesName}"
                              Margin="0,0,0,4"
                              Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>
                    <Grid Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DayLimitBox"
                                 Grid.Column="0"
                                 Text="{Binding EditDaysOfMail, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsDayLimitFieldEnabled}"
                                 AutomationProperties.Name="{x:Static strings:Strings.ViewManager_DayLimitFieldName}"
                                 MaxLength="4"
                                 PreviewTextInput="DayLimitBox_PreviewTextInput"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}"
                                   Text="{x:Static strings:Strings.ViewManager_DaysUnitLabel}"/>
                    </Grid>

                    <!-- Options -->
                    <TextBlock Style="{StaticResource SectionLabel}" Text="{x:Static strings:Strings.ViewManager_OptionsHeading}"
                               Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>
                    <CheckBox Content="{x:Static strings:Strings.ViewManager_DefaultViewCheckbox}"
                              IsChecked="{Binding EditIsDefault}"
                              AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SetAsDefaultViewName}"
                              Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>

                    <!-- Name (last before Save — shown after day limit so the suggestion already includes it) -->
                    <TextBlock Style="{StaticResource SectionLabel}" Text="{x:Static strings:Strings.ViewManager_NameHeading}"
                               Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>
                    <TextBox x:Name="NameBox"
                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="{x:Static strings:Strings.ViewManager_ViewNameFieldName}"
                             MaxLength="120"
                             Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}"/>

                    <!-- Save / Cancel buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0"
                                Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVis}}">
                        <Button Content="{x:Static strings:Strings.ViewManager_SaveButton}"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding CanSave}"
                                MinWidth="80" Margin="0,0,8,0"
                                ToolTip="{x:Static strings:Strings.ViewManager_SaveButtonToolTip}"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SaveCurrentStateToSelectedViewName}"/>
                        <!-- Cancel is only shown in manage mode; create mode uses the dialog's Cancel button -->
                        <Button Content="{x:Static strings:Strings.ViewManager_CancelButton}"
                                Command="{Binding CancelEditCommand}"
                                MinWidth="80"
                                Visibility="{Binding IsManageMode, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.Name="{x:Static strings:Strings.ViewManager_CancelEditingDiscardChangesName}"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── Bottom buttons ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <!-- Visible only in create mode (opened via Save View…) -->
            <Button x:Name="SaveViewAndCloseButton"
                    Content="{x:Static strings:Strings.ViewManager_SaveViewButton}"
                    IsEnabled="{Binding CanSave}"
                    MinWidth="90" Margin="0,0,8,0"
                    Visibility="Collapsed"
                    Click="SaveViewAndCloseButton_Click"
                    AutomationProperties.Name="{x:Static strings:Strings.ViewManager_SaveViewAndCloseName}"/>
            <!-- Close in manage mode; Cancel in create mode (content set in code-behind) -->
            <Button x:Name="CloseButton"
                    Content="{x:Static strings:Strings.ViewManager_CloseButton}"
                    IsCancel="True"
                    MinWidth="80"
                    Click="CloseButton_Click"
                    AutomationProperties.Name="{x:Static strings:Strings.ViewManager_CloseViewManagerName}"/>
        </StackPanel>
    </Grid>
</Window>
