<Window x:Class="QuickMail.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{x:Static strings:Strings.Settings_Title}"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabs -->
        <TabControl Grid.Row="0" Margin="0,0,0,10">
            <!-- General Settings Tab -->
            <TabItem Header="{x:Static strings:Strings.Settings_General_TabHeader}" AutomationProperties.Name="{x:Static strings:Strings.Settings_General_TabAutomationName}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" >
                        <!-- Message List Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_MessageList_GroupHeader}" Padding="10" Margin="0,0,0,15" AutomationProperties.Name="{x:Static strings:Strings.Settings_MessageList_GroupAutomationName}">
                            <StackPanel>
                                <!-- Preview Lines -->
                                <StackPanel>
                                    <Label x:Name="PreviewLinesLabel"
                                           Content="{x:Static strings:Strings.Settings_PreviewLines_Label}"
                                           Target="{Binding ElementName=PreviewLinesCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="PreviewLinesCombo"
                                              SelectedValue="{Binding PreviewLines, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              AutomationProperties.LabeledBy="{Binding ElementName=PreviewLinesLabel}">
                                        <ComboBoxItem Tag="0" Content="{x:Static strings:Strings.Settings_PreviewLines_Off}"/>
                                        <ComboBoxItem Tag="1" Content="{x:Static strings:Strings.Settings_PreviewLines_1}"/>
                                        <ComboBoxItem Tag="2" Content="{x:Static strings:Strings.Settings_PreviewLines_2}"/>
                                        <ComboBoxItem Tag="3" Content="{x:Static strings:Strings.Settings_PreviewLines_3}"/>
                                        <ComboBoxItem Tag="4" Content="{x:Static strings:Strings.Settings_PreviewLines_4}"/>
                                        <ComboBoxItem Tag="5" Content="{x:Static strings:Strings.Settings_PreviewLines_5}"/>
                                    </ComboBox>
                                    <TextBlock Text="{x:Static strings:Strings.Settings_PreviewLines_Hint}"
                                               Foreground="{DynamicResource Theme.TextSecondary}"
                                               FontSize="{DynamicResource Theme.FontSizeSmall}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Show Message Status -->
                                <CheckBox Content="{x:Static strings:Strings.Settings_ShowMessageStatus}"
                                          IsChecked="{Binding ShowMessageStatus, Mode=TwoWay}"
                                          Margin="0,8,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_ShowMessageStatus_AutomationName}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- View Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_View_GroupHeader}" Padding="10" Margin="0,0,0,15" AutomationProperties.Name="{x:Static strings:Strings.Settings_View_GroupAutomationName}">
                            <StackPanel>
                                <!-- View Mode -->
                                <StackPanel>
                                    <Label x:Name="ViewModeLabel"
                                           Content="{x:Static strings:Strings.Settings_DisplayMode_Label}"
                                           Target="{Binding ElementName=ViewModeCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="ViewModeCombo"
                                              SelectedValue="{Binding ViewMode, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              AutomationProperties.LabeledBy="{Binding ElementName=ViewModeLabel}">
                                        <ComboBoxItem Tag="messages" Content="{x:Static strings:Strings.Settings_ViewMode_Messages}"/>
                                        <ComboBoxItem Tag="conversations" Content="{x:Static strings:Strings.Settings_ViewMode_Conversations}"/>
                                        <ComboBoxItem Tag="from" Content="{x:Static strings:Strings.Settings_ViewMode_BySender}"/>
                                        <ComboBoxItem Tag="to" Content="{x:Static strings:Strings.Settings_ViewMode_ByRecipient}"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Language Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_Language_GroupHeader}" Padding="10" Margin="0,0,0,15" AutomationProperties.Name="{x:Static strings:Strings.Settings_Language_GroupAutomationName}">
                            <StackPanel>
                                <StackPanel>
                                    <Label x:Name="UILanguageLabel"
                                           Content="{x:Static strings:Strings.Settings_Language}"
                                           Target="{Binding ElementName=UILanguageCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="UILanguageCombo"
                                              SelectedValue="{Binding UiLanguage, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              AutomationProperties.LabeledBy="{Binding ElementName=UILanguageLabel}"
                                              SelectionChanged="UILanguageCombo_SelectionChanged">
                                        <ComboBoxItem Tag="" Content="{x:Static strings:Strings.Settings_Language_FollowWindows}"/>
                                        <ComboBoxItem Tag="en" Content="{x:Static strings:Strings.Settings_Language_English}"/>
                                        <ComboBoxItem Tag="es" Content="{x:Static strings:Strings.Settings_Language_Spanish}"/>
                                        <ComboBoxItem Tag="de" Content="{x:Static strings:Strings.Settings_Language_German}"/>
                                        <ComboBoxItem Tag="fr" Content="{x:Static strings:Strings.Settings_Language_French}"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Sync Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_Sync_GroupHeader}" Padding="10" AutomationProperties.Name="{x:Static strings:Strings.Settings_Sync_GroupAutomationName}">
                            <StackPanel>
                                <!-- Sync Days -->
                                <StackPanel>
                                    <Label x:Name="SyncDaysLabel" Margin="0,0,0,0"
                                           Content="{x:Static strings:Strings.Settings_SyncRange_Label}"
                                           Target="{Binding ElementName=SyncDaysCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="SyncDaysCombo"
                                              SelectedValue="{Binding SyncDays, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              AutomationProperties.LabeledBy="{Binding ElementName=SyncDaysLabel}">
                                        <ComboBoxItem Tag="7" Content="{x:Static strings:Strings.Settings_SyncRange_7Days}"/>
                                        <ComboBoxItem Tag="30" Content="{x:Static strings:Strings.Settings_SyncRange_30Days}"/>
                                        <ComboBoxItem Tag="180" Content="{x:Static strings:Strings.Settings_SyncRange_6Months}"/>
                                        <ComboBoxItem Tag="365" Content="{x:Static strings:Strings.Settings_SyncRange_1Year}"/>
                                        <ComboBoxItem Tag="0" Content="{x:Static strings:Strings.Settings_SyncRange_AllMail}"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Initial Sync Count -->
                                <StackPanel Margin="0,8,0,0">
                                    <Label x:Name="InitialSyncLabel"
                                           Content="{x:Static strings:Strings.Settings_InitialFetchCount_Label}"
                                           Target="{Binding ElementName=InitialSyncCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="InitialSyncCombo"
                                              SelectedValue="{Binding InitialSyncCount, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              AutomationProperties.LabeledBy="{Binding ElementName=InitialSyncLabel}">
                                        <ComboBoxItem Tag="100" Content="{x:Static strings:Strings.Settings_InitialFetchCount_100}"/>
                                        <ComboBoxItem Tag="250" Content="{x:Static strings:Strings.Settings_InitialFetchCount_250}"/>
                                        <ComboBoxItem Tag="500" Content="{x:Static strings:Strings.Settings_InitialFetchCount_500}"/>
                                        <ComboBoxItem Tag="1000" Content="{x:Static strings:Strings.Settings_InitialFetchCount_1000}"/>
                                        <ComboBoxItem Tag="0" Content="{x:Static strings:Strings.Settings_InitialFetchCount_All}"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Mail Actions Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_MailActions_GroupHeader}" Padding="10" Margin="0,10,0,0"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_MailActions_GroupAutomationName}">
                            <StackPanel>
                                <CheckBox Content="{x:Static strings:Strings.Settings_ConfirmEmptyTrash}"
                                          IsChecked="{Binding ConfirmEmptyTrash, Mode=TwoWay}"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_ConfirmEmptyTrash_AutomationName}"/>
                                <TextBlock Text="{x:Static strings:Strings.Settings_ConfirmEmptyTrash_Hint}"
                                           Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Composing Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_Composing_GroupHeader}" Padding="10" Margin="0,10,0,0"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_Composing_GroupAutomationName}">
                            <StackPanel>
                                <CheckBox Content="{x:Static strings:Strings.Settings_AutoSaveDrafts}"
                                          IsChecked="{Binding AutoSaveDrafts, Mode=TwoWay}"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AutoSaveDrafts_AutomationName}"/>
                                <TextBlock Text="{x:Static strings:Strings.Settings_AutoSaveDrafts_Hint}"
                                           Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="0,3,0,8" TextWrapping="Wrap"/>

                                <StackPanel Margin="0,0,0,8">
                                    <Label x:Name="AutoSaveIntervalLabel"
                                           Content="{x:Static strings:Strings.Settings_AutoSaveInterval_Label}"
                                           Target="{Binding ElementName=AutoSaveIntervalCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="AutoSaveIntervalCombo"
                                              SelectedValue="{Binding AutoSaveIntervalSeconds, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              IsEnabled="{Binding AutoSaveDrafts}"
                                              AutomationProperties.LabeledBy="{Binding ElementName=AutoSaveIntervalLabel}">
                                        <ComboBoxItem Tag="30" Content="{x:Static strings:Strings.Settings_AutoSaveInterval_30Sec}"/>
                                        <ComboBoxItem Tag="60" Content="{x:Static strings:Strings.Settings_AutoSaveInterval_1Min}"/>
                                        <ComboBoxItem Tag="120" Content="{x:Static strings:Strings.Settings_AutoSaveInterval_2Min}"/>
                                        <ComboBoxItem Tag="300" Content="{x:Static strings:Strings.Settings_AutoSaveInterval_5Min}"/>
                                        <ComboBoxItem Tag="600" Content="{x:Static strings:Strings.Settings_AutoSaveInterval_10Min}"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel>
                                    <Label x:Name="DefaultComposeModeLabel"
                                           Content="{x:Static strings:Strings.Settings_DefaultComposeMode_Label}"
                                           Target="{Binding ElementName=DefaultComposeModeCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="DefaultComposeModeCombo"
                                              SelectedValue="{Binding DefaultComposeMode, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              AutomationProperties.LabeledBy="{Binding ElementName=DefaultComposeModeLabel}">
                                        <ComboBoxItem Tag="plain" Content="{x:Static strings:Strings.Settings_ComposeMode_PlainText}"/>
                                        <ComboBoxItem Tag="markdown" Content="{x:Static strings:Strings.Settings_ComposeMode_Markdown}"/>
                                        <ComboBoxItem Tag="html" Content="{x:Static strings:Strings.Settings_ComposeMode_Html}"/>
                                    </ComboBox>
                                    <TextBlock Text="{x:Static strings:Strings.Settings_DefaultComposeMode_Hint}"
                                               Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Screen Reader Announcements Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_ScreenReaderAnnouncements_GroupHeader}" Padding="10" Margin="0,10,0,0"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_ScreenReaderAnnouncements_GroupAutomationName}">
                            <StackPanel>
                                <CheckBox Content="{x:Static strings:Strings.Settings_CustomAnnouncements}"
                                          IsChecked="{Binding CustomAnnouncements, Mode=TwoWay}"
                                          FontWeight="SemiBold"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_CustomAnnouncements_AutomationName}"/>
                                <TextBlock Text="{x:Static strings:Strings.Settings_CustomAnnouncements_Hint}"
                                           Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="0,2,0,8"/>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceHints}"
                                          IsChecked="{Binding AnnounceHints, Mode=TwoWay}"
                                          Margin="16,0,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceHints_AutomationName}"/>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceStatus}"
                                          IsChecked="{Binding AnnounceStatus, Mode=TwoWay}"
                                          Margin="16,4,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceStatus_AutomationName}"/>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceResults}"
                                          IsChecked="{Binding AnnounceResults, Mode=TwoWay}"
                                          Margin="16,4,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceResults_AutomationName}"/>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceSpellingWhileTyping}"
                                          IsChecked="{Binding AnnounceSpellingWhileTyping, Mode=TwoWay}"
                                          Margin="16,4,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceSpellingWhileTyping_AutomationName}"/>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceSpellingWhileNavigating}"
                                          IsChecked="{Binding AnnounceSpellingWhileNavigating, Mode=TwoWay}"
                                          Margin="16,4,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceSpellingWhileNavigating_AutomationName}"
                                          AutomationProperties.HelpText="{x:Static strings:Strings.Settings_AnnounceSpellingWhileNavigating_HelpText}"/>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceSpellingSuggestions}"
                                          IsChecked="{Binding AnnounceSpellingSuggestions, Mode=TwoWay}"
                                          Margin="16,4,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceSpellingSuggestions_AutomationName}"/>

                                <TextBlock Text="{x:Static strings:Strings.Settings_SpellingSuggestionsVerbosity_Header}"
                                           Margin="32,6,0,2"/>
                                <StackPanel KeyboardNavigation.TabNavigation="Once"
                                            KeyboardNavigation.DirectionalNavigation="Cycle"
                                            Margin="32,0,0,4">
                                    <RadioButton Content="{x:Static strings:Strings.Settings_VerbosityNumbersWithSuggestions}"
                                                 IsChecked="{Binding IsVerbosityNumbersWithSuggestions, Mode=TwoWay}"
                                                 GroupName="SpellingSuggestionsVerbosity"
                                                 Checked="RadioButton_Checked"
                                                 AutomationProperties.Name="{x:Static strings:Strings.Settings_VerbosityNumbersWithSuggestions_AutomationName}"
                                                 AutomationProperties.HelpText="{x:Static strings:Strings.Settings_VerbosityNumbersWithSuggestions_HelpText}"/>
                                    <RadioButton Content="{x:Static strings:Strings.Settings_VerbosityJustSuggestions}"
                                                 IsChecked="{Binding IsVerbosityJustSuggestions, Mode=TwoWay}"
                                                 GroupName="SpellingSuggestionsVerbosity"
                                                 Checked="RadioButton_Checked"
                                                 AutomationProperties.Name="{x:Static strings:Strings.Settings_VerbosityJustSuggestions_AutomationName}"
                                                 AutomationProperties.HelpText="{x:Static strings:Strings.Settings_VerbosityJustSuggestions_HelpText}"/>
                                </StackPanel>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceFormattingWhileNavigating}"
                                          IsChecked="{Binding AnnounceFormattingWhileNavigating, Mode=TwoWay}"
                                          Margin="16,4,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceFormattingWhileNavigating_AutomationName}"/>

                                <CheckBox Content="{x:Static strings:Strings.Settings_AnnounceFlagStatus}"
                                          IsChecked="{Binding AnnounceFlagStatus, Mode=TwoWay}"
                                          Margin="16,4,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_AnnounceFlagStatus_AutomationName}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced Tab -->
            <TabItem Header="{x:Static strings:Strings.Settings_Advanced_TabHeader}" AutomationProperties.Name="{x:Static strings:Strings.Settings_Advanced_TabAutomationName}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- QuickMail Logging Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_Logging_GroupHeader}" Padding="10" Margin="0,0,0,15"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_Logging_GroupAutomationName}">
                            <StackPanel>
                                <CheckBox Content="{x:Static strings:Strings.Settings_EnableLogging}"
                                          IsChecked="{Binding EnableLogging, Mode=TwoWay}"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_EnableLogging_AutomationName}"/>
                                <Button x:Name="DeleteLogButton"
                                        Content="{x:Static strings:Strings.Settings_DeleteLog}"
                                        HorizontalAlignment="Left"
                                        Margin="0,10,0,0"
                                        Click="DeleteLogButton_Click"
                                        AutomationProperties.Name="{x:Static strings:Strings.Settings_DeleteLog_AutomationName}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Log Format Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_LogFormat_GroupHeader}" Padding="10" Margin="0,0,0,15"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_LogFormat_GroupAutomationName}">
                            <StackPanel KeyboardNavigation.TabNavigation="Once"
                                        KeyboardNavigation.DirectionalNavigation="Cycle">
                                <RadioButton Content="{x:Static strings:Strings.Settings_LogFormat_ActionFirst}"
                                             IsChecked="{Binding IsLogFormatActionFirst, Mode=TwoWay}"
                                             GroupName="LogFormat"
                                             Checked="RadioButton_Checked"
                                             AutomationProperties.Name="{x:Static strings:Strings.Settings_LogFormat_ActionFirst_AutomationName}"
                                             AutomationProperties.HelpText="{x:Static strings:Strings.Settings_LogFormat_ActionFirst_HelpText}"/>
                                <TextBlock Text="{x:Static strings:Strings.Settings_LogFormat_ActionFirst_Example}"
                                           Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="16,2,0,8"
                                           FontFamily="{DynamicResource Theme.FontFamilyMono}"/>
                                <RadioButton Content="{x:Static strings:Strings.Settings_LogFormat_TimeFirst}"
                                             IsChecked="{Binding IsLogFormatTimeFirst, Mode=TwoWay}"
                                             GroupName="LogFormat"
                                             Checked="RadioButton_Checked"
                                             AutomationProperties.Name="{x:Static strings:Strings.Settings_LogFormat_TimeFirst_AutomationName}"
                                             AutomationProperties.HelpText="{x:Static strings:Strings.Settings_LogFormat_TimeFirst_HelpText}"/>
                                <TextBlock Text="{x:Static strings:Strings.Settings_LogFormat_TimeFirst_Example}"
                                           Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="16,2,0,0"
                                           FontFamily="{DynamicResource Theme.FontFamilyMono}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Keyboard Shortcuts Tab -->
            <TabItem Header="{x:Static strings:Strings.Settings_KeyboardShortcuts_TabHeader}" AutomationProperties.Name="{x:Static strings:Strings.Settings_KeyboardShortcuts_TabAutomationName}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Helper text -->
                    <TextBlock Grid.Row="0"
                               Text="{x:Static strings:Strings.Settings_KeyboardShortcuts_HelperText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource Theme.TextSecondary}"/>

                    <!-- Hotkeys ListView -->
                    <ListView Grid.Row="1"
                              x:Name="HotkeyListView"
                              ItemsSource="{Binding HotkeyRows}"
                              SelectedItem="{Binding SelectedHotkey, Mode=TwoWay}"
                              SelectionMode="Single"
                              BorderThickness="1"
                              Margin="0,0,0,6"
                              KeyDown="HotkeyListView_KeyDown"
                              SelectionChanged="HotkeyListView_SelectionChanged"
                              AutomationProperties.Name="{x:Static strings:Strings.Settings_KeyboardShortcuts_ListAutomationName}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{x:Static strings:Strings.Settings_KeyboardShortcuts_ColumnCategory}" DisplayMemberBinding="{Binding Category}" Width="90"/>
                                <GridViewColumn Header="{x:Static strings:Strings.Settings_KeyboardShortcuts_ColumnCommand}" DisplayMemberBinding="{Binding Title}" Width="200"/>
                                <GridViewColumn Header="{x:Static strings:Strings.Settings_KeyboardShortcuts_ColumnShortcut}" DisplayMemberBinding="{Binding ActiveGesture}" Width="130"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Action buttons — Grid.Row="2" so Tab flows: list → Set → Restore → Save/Cancel -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal">
                        <Button x:Name="SetShortcutButton"
                                Content="{x:Static strings:Strings.Settings_SetShortcut}"
                                Click="SetShortcutButton_Click"
                                IsEnabled="False"
                                Padding="6,3"
                                Margin="0,0,8,0"
                                AutomationProperties.Name="{x:Static strings:Strings.Settings_SetShortcut_AutomationName}"/>
                        <Button x:Name="RestoreDefaultButton"
                                Content="{x:Static strings:Strings.Settings_RestoreDefault}"
                                Click="RestoreDefaultButton_Click"
                                IsEnabled="False"
                                Padding="6,3"
                                AutomationProperties.Name="{x:Static strings:Strings.Settings_RestoreDefault_AutomationName}"/>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- Windowing Tab -->
            <TabItem Header="{x:Static strings:Strings.Settings_Windowing_TabHeader}" AutomationProperties.Name="{x:Static strings:Strings.Settings_Windowing_TabAutomationName}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Message open mode -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_MessageOpenMode_GroupHeader}" Padding="10" Margin="0,0,0,15"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_MessageOpenMode_GroupAutomationName}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}"
                                           Text="{x:Static strings:Strings.Settings_MessageOpenMode_Description}"/>
                                <StackPanel KeyboardNavigation.TabNavigation="Once"
                                            KeyboardNavigation.DirectionalNavigation="Cycle">
                                    <RadioButton Content="{x:Static strings:Strings.Settings_MessageOpenMode_ReadingPane}"
                                                 IsChecked="{Binding IsReadingPaneMode, Mode=TwoWay}"
                                                 GroupName="MessageOpenMode"
                                                 Checked="RadioButton_Checked"
                                                 AutomationProperties.Name="{x:Static strings:Strings.Settings_MessageOpenMode_ReadingPane_AutomationName}"
                                                 AutomationProperties.HelpText="{x:Static strings:Strings.Settings_MessageOpenMode_ReadingPane_HelpText}"/>
                                    <TextBlock Text="{x:Static strings:Strings.Settings_MessageOpenMode_ReadingPane_Hint}"
                                               Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="16,2,0,8"/>
                                    <RadioButton Content="{x:Static strings:Strings.Settings_MessageOpenMode_Tab}"
                                                 IsChecked="{Binding IsTabMode, Mode=TwoWay}"
                                                 GroupName="MessageOpenMode"
                                                 Checked="RadioButton_Checked"
                                                 AutomationProperties.Name="{x:Static strings:Strings.Settings_MessageOpenMode_Tab_AutomationName}"
                                                 AutomationProperties.HelpText="{x:Static strings:Strings.Settings_MessageOpenMode_Tab_HelpText}"/>
                                    <TextBlock Text="{x:Static strings:Strings.Settings_MessageOpenMode_Tab_Hint}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="16,2,0,8"/>
                                    <RadioButton Content="{x:Static strings:Strings.Settings_MessageOpenMode_Window}"
                                                 IsChecked="{Binding IsWindowMode, Mode=TwoWay}"
                                                 GroupName="MessageOpenMode"
                                                 Checked="RadioButton_Checked"
                                                 AutomationProperties.Name="{x:Static strings:Strings.Settings_MessageOpenMode_Window_AutomationName}"
                                                 AutomationProperties.HelpText="{x:Static strings:Strings.Settings_MessageOpenMode_Window_HelpText}"/>
                                    <TextBlock Text="{x:Static strings:Strings.Settings_MessageOpenMode_Window_Hint}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Theme.TextSecondary}" FontSize="{DynamicResource Theme.FontSizeSmall}" Margin="16,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Tab behaviour -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_TabBehaviour_GroupHeader}" Padding="10" Margin="0,0,0,0"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_TabBehaviour_GroupAutomationName}">
                            <StackPanel>
                                <CheckBox Content="{x:Static strings:Strings.Settings_ConfirmCloseTabWithUnsaved}"
                                          IsChecked="{Binding ConfirmCloseTabWithUnsaved, Mode=TwoWay}"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_ConfirmCloseTabWithUnsaved_AutomationName}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- Appearance Tab -->
            <TabItem Header="{x:Static strings:Strings.Settings_Appearance_TabHeader}" AutomationProperties.Name="{x:Static strings:Strings.Settings_Appearance_TabAutomationName}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- High Contrast notice — visible only while Windows HC is active. -->
                        <TextBlock Text="{x:Static strings:Strings.Settings_HighContrastActive_Notice}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   Visibility="{Binding IsHighContrastActive, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Theme Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_Theme_GroupHeader}" Padding="10" Margin="0,0,0,15"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_Theme_GroupAutomationName}">
                            <StackPanel>
                                <Label x:Name="ThemeLabel"
                                       Content="{x:Static strings:Strings.Settings_Theme_Label}"
                                       Target="{Binding ElementName=ThemeCombo}"
                                       FontWeight="SemiBold"/>
                                <ComboBox x:Name="ThemeCombo"
                                          ItemsSource="{Binding ThemeOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding AppearanceThemeId, Mode=TwoWay}"
                                          AutomationProperties.LabeledBy="{Binding ElementName=ThemeLabel}"/>
                                <TextBlock Text="{x:Static strings:Strings.Settings_Theme_Hint}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Theme.TextSecondary}"
                                           FontSize="{DynamicResource Theme.FontSizeSmall}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Text Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_Text_GroupHeader}" Padding="10" Margin="0,0,0,15"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_Text_GroupAutomationName}">
                            <StackPanel>
                                <Label x:Name="FontLabel"
                                       Content="{x:Static strings:Strings.Settings_Font_Label}"
                                       Target="{Binding ElementName=FontCombo}"
                                       FontWeight="SemiBold"/>
                                <ComboBox x:Name="FontCombo"
                                          ItemsSource="{Binding FontOptions}"
                                          SelectedItem="{Binding AppearanceFontOption, Mode=TwoWay}"
                                          AutomationProperties.LabeledBy="{Binding ElementName=FontLabel}"/>

                                <StackPanel Margin="0,8,0,0">
                                    <Label x:Name="TextSizeLabel"
                                           Content="{x:Static strings:Strings.Settings_TextSize_Label}"
                                           Target="{Binding ElementName=TextSizeCombo}"
                                           FontWeight="SemiBold"/>
                                    <ComboBox x:Name="TextSizeCombo"
                                              SelectedValue="{Binding AppearanceTextScalePercent, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              AutomationProperties.LabeledBy="{Binding ElementName=TextSizeLabel}">
                                        <ComboBoxItem Tag="100" Content="{x:Static strings:Strings.Settings_TextSize_100}"/>
                                        <ComboBoxItem Tag="110" Content="{x:Static strings:Strings.Settings_TextSize_110}"/>
                                        <ComboBoxItem Tag="125" Content="{x:Static strings:Strings.Settings_TextSize_125}"/>
                                        <ComboBoxItem Tag="150" Content="{x:Static strings:Strings.Settings_TextSize_150}"/>
                                        <ComboBoxItem Tag="175" Content="{x:Static strings:Strings.Settings_TextSize_175}"/>
                                        <ComboBoxItem Tag="200" Content="{x:Static strings:Strings.Settings_TextSize_200}"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Vision Group -->
                        <GroupBox Header="{x:Static strings:Strings.Settings_Vision_GroupHeader}" Padding="10"
                                  AutomationProperties.Name="{x:Static strings:Strings.Settings_Vision_GroupAutomationName}">
                            <StackPanel>
                                <CheckBox Content="{x:Static strings:Strings.Settings_UnderlineLinks}"
                                          IsChecked="{Binding AppearanceUnderlineLinks, Mode=TwoWay}"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_UnderlineLinks_AutomationName}"/>
                                <CheckBox Content="{x:Static strings:Strings.Settings_ThickFocus}"
                                          IsChecked="{Binding AppearanceThickFocus, Mode=TwoWay}"
                                          Margin="0,6,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_ThickFocus_AutomationName}"/>
                                <CheckBox Content="{x:Static strings:Strings.Settings_ForceMessageTheme}"
                                          IsChecked="{Binding AppearanceForceMessageTheme, Mode=TwoWay}"
                                          Margin="0,6,0,0"
                                          AutomationProperties.Name="{x:Static strings:Strings.Settings_ForceMessageTheme_AutomationName}"/>
                                <TextBlock Text="{x:Static strings:Strings.Settings_ForceMessageTheme_Hint}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Theme.TextSecondary}"
                                           FontSize="{DynamicResource Theme.FontSizeSmall}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    >
            <Button x:Name="SaveButton"
                    Content="{x:Static strings:Strings.Common_Save}"
                    IsDefault="True"
                    Click="SaveButton_Click"
                    MinWidth="75"
                    AutomationProperties.Name="{x:Static strings:Strings.Settings_Save_AutomationName}"/>
            <Button Content="{x:Static strings:Strings.Common_Cancel}"
                    IsCancel="True"
                    MinWidth="75"
                    AutomationProperties.Name="{x:Static strings:Strings.Settings_Cancel_AutomationName}"/>
        </StackPanel>

    </Grid>
</Window>
