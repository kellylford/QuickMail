<Window x:Class="QuickMail.Views.ThemeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickMail.Views"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{x:Static strings:Strings.ThemeManager_Title}"
        Height="620" Width="580"
        MinHeight="460" MinWidth="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="130"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Theme list — F6 stop 1 -->
        <ListBox x:Name="ThemesList"
                 Grid.Row="0" Grid.Column="0"
                 AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_Themes_Name}"
                 ItemsSource="{Binding Themes}"
                 SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                 GotKeyboardFocus="ThemesList_GotKeyboardFocus"
                 KeyboardNavigation.TabNavigation="Once">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}"/>
                    <Setter Property="Padding" Value="6,4"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <local:AriaHiddenTextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                        <local:AriaHiddenTextBlock Text="{Binding DetailLabel}"
                                                   Foreground="{DynamicResource Theme.TextSecondary}"
                                                   FontSize="{DynamicResource Theme.FontSizeSmall}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Action buttons — F6 stop 2 -->
        <StackPanel x:Name="ButtonColumn"
                    Grid.Row="0" Grid.Column="1"
                    Margin="10,0,0,0"
                    KeyboardNavigation.TabNavigation="Continue">
            <Button Content="{x:Static strings:Strings.ThemeManager_Apply}"
                    Command="{Binding ApplyCommand}"
                    IsEnabled="{Binding CanApply}"
                    MinWidth="140" Margin="0,0,0,6"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_Apply_Name}"/>
            <Button Content="{x:Static strings:Strings.ThemeManager_Duplicate}"
                    Command="{Binding DuplicateCommand}"
                    IsEnabled="{Binding CanDuplicate}"
                    MinWidth="140" Margin="0,0,0,6"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_Duplicate_Name}"/>
            <Button Content="{x:Static strings:Strings.ThemeManager_Rename}"
                    Command="{Binding RenameCommand}"
                    IsEnabled="{Binding CanRename}"
                    MinWidth="140" Margin="0,0,0,6"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_Rename_Name}"/>
            <Button Content="{x:Static strings:Strings.Common_Delete}"
                    Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding CanDelete}"
                    MinWidth="140" Margin="0,0,0,6"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_DeleteButtonName}"/>
            <Button x:Name="ExportButton"
                    Content="{x:Static strings:Strings.ThemeManager_Export}"
                    Command="{Binding ExportCommand}"
                    IsEnabled="{Binding CanExport}"
                    MinWidth="140" Margin="0,12,0,6"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_Export_Name}"/>
            <Button x:Name="ImportButton"
                    Content="{x:Static strings:Strings.ThemeManager_Import}"
                    Command="{Binding ImportCommand}"
                    MinWidth="140" Margin="0,0,0,6"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_Import_Name}"/>
            <Button Content="{x:Static strings:Strings.ThemeManager_OpenThemesFolder}"
                    Command="{Binding OpenThemesFolderCommand}"
                    MinWidth="140" Margin="0,12,0,0"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_OpenThemesFolder_Name}"/>
        </StackPanel>

        <!-- Theme description — a read-only account of the selected theme's colors
             and where they are used, for users who cannot see the swatches.
             Read-only TextBox so a screen reader can arrow through the text. -->
        <Label x:Name="DescriptionLabel"
               Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
               Content="{x:Static strings:Strings.ThemeManager_ThemeDescription}"
               Target="{Binding ElementName=DescriptionBox}"
               Margin="0,10,0,2"/>
        <TextBox x:Name="DescriptionBox"
                 Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                 Text="{Binding SelectedThemeDescription, Mode=OneWay}"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Padding="6"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 AutomationProperties.LabeledBy="{Binding ElementName=DescriptionLabel}"/>

        <!-- Inline name panel for Duplicate / Rename (no nested modal prompt —
             modal + editable text over a live WebView2 is the documented
             dispatcher-deadlock pattern). -->
        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                Margin="0,10,0,0" Padding="8"
                Background="{DynamicResource Theme.SurfaceBackground}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                Visibility="{Binding IsNamePanelOpen, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Label x:Name="NameLabel"
                       Content="{x:Static strings:Strings.ThemeManager_Name}"
                       Target="{Binding ElementName=NameBox}"
                       VerticalAlignment="Center"/>
                <TextBox x:Name="NameBox"
                         Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="220"
                         VerticalAlignment="Center"
                         AutomationProperties.LabeledBy="{Binding ElementName=NameLabel}"
                         KeyDown="NameBox_KeyDown"/>
                <Button Content="{x:Static strings:Strings.ThemeManager_NameOK}"
                        Command="{Binding ConfirmNameCommand}"
                        MinWidth="70" Margin="8,0,0,0"
                        AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_ConfirmNameButtonName}"/>
                <Button Content="{x:Static strings:Strings.Common_Cancel}"
                        Command="{Binding CancelNameCommand}"
                        MinWidth="70" Margin="6,0,0,0"
                        AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_CancelNameButtonName}"/>
            </StackPanel>
        </Border>

        <!-- Close -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="CloseButton"
                    Content="{x:Static strings:Strings.ThemeManager_Close}"
                    Click="CloseButton_Click"
                    MinWidth="80"
                    AutomationProperties.Name="{x:Static strings:Strings.ThemeManager_CloseButtonName}"/>
        </StackPanel>
    </Grid>
</Window>
