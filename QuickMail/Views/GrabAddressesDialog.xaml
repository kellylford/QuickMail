<Window x:Class="QuickMail.Views.GrabAddressesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{x:Static strings:Strings.GrabAddresses_Title}"
        Height="420" Width="420"
        MinHeight="300" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{x:Static strings:Strings.GrabAddresses_SelectAddressesPrompt}"
                   Margin="0,0,0,8"/>

        <!-- Address checklist -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      IsTabStop="False"
                      AutomationProperties.Name="{x:Static strings:Strings.GrabAddresses_AddressesFromMessage}">
            <ItemsControl x:Name="AddressList"
                          KeyboardNavigation.TabNavigation="Once"
                          KeyboardNavigation.DirectionalNavigation="Contained"
                          IsTabStop="False"
                          Focusable="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsChecked}"
                                  Content="{Binding Display}"
                                  AutomationProperties.Name="{Binding Display}"
                                  Margin="0,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Group section -->
        <StackPanel Grid.Row="2" Margin="0,10,0,4">
            <CheckBox x:Name="AddToGroupCheckBox"
                      Content="{x:Static strings:Strings.GrabAddresses_AddToGroup}"
                      Margin="0,0,0,6"/>
            <ComboBox x:Name="GroupComboBox"
                      AutomationProperties.Name="{x:Static strings:Strings.GrabAddresses_Group}"
                      Margin="0,0,0,4"/>
            <TextBlock x:Name="NewGroupNameLabel"
                       Text="{x:Static strings:Strings.GrabAddresses_NewGroupNameLabel}"
                       Margin="0,2,0,2"/>
            <TextBox x:Name="NewGroupNameBox"
                     AutomationProperties.Name="{x:Static strings:Strings.GrabAddresses_NewGroupName}"
                     MaxLength="100"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="SaveButton"
                    Content="{x:Static strings:Strings.Common_Save}"
                    IsDefault="True"
                    AutomationProperties.Name="{x:Static strings:Strings.GrabAddresses_SaveSelectedAddresses}"
                    MinWidth="80"
                    Click="Save_Click"/>
            <Button Content="{x:Static strings:Strings.Common_Cancel}"
                    IsCancel="True"
                    MinWidth="80"
                    Margin="8,0,0,0"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
