<Window x:Class="QuickMail.Views.GrabAddressesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add to Address Book"
        Height="340" Width="420"
        MinHeight="240" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <DockPanel Margin="12">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="_Save"
                    IsDefault="True"
                    AutomationProperties.Name="Save selected addresses"
                    MinWidth="80"
                    Click="Save_Click"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    MinWidth="80"
                    Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Select addresses to add to your address book:"
                   Margin="0,0,0,8"/>

        <!-- Address checklist -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      IsTabStop="False"
                      AutomationProperties.Name="Addresses from message">
            <ItemsControl x:Name="AddressList"
                          KeyboardNavigation.TabNavigation="Contained"
                          KeyboardNavigation.DirectionalNavigation="Contained"
                          IsTabStop="False"
                          AutomationProperties.AccessKey=""
                          Focusable="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsChecked}"
                                  Content="{Binding Display}"
                                  AutomationProperties.Name="{Binding Display}"
                                  Margin="0,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
