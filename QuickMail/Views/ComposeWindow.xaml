<Window x:Class="QuickMail.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:QuickMail.Controls"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="{Binding WindowTitle}"
        Height="540" Width="680"
        MinHeight="360" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Alt"  Command="{Binding SendCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveDraftCommand}"/>
        <KeyBinding Key="A" Modifiers="Ctrl+Shift" Command="{Binding AddAttachmentsCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- Menu bar. Reached with Alt or F10 (not a tab stop, per platform convention).
             Every item dispatches to the same handler or command as its keyboard
             shortcut; InputGestureText must match the registered default gesture. -->
        <Menu DockPanel.Dock="Top"
              IsTabStop="False"
              KeyboardNavigation.TabNavigation="None">
            <MenuItem Header="{x:Static strings:Strings.Compose_Menu_File}">
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Send}" InputGestureText="Alt+S" Click="MenuSend_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_SaveDraft}" Command="{Binding SaveDraftCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_InsertTemplate}" Command="{Binding InsertTemplateCommand}"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_SaveAsTemplate}" Command="{Binding SaveAsTemplateCommand}"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_AddAttachments}" Command="{Binding AddAttachmentsCommand}" InputGestureText="Ctrl+Shift+A"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Close}" Command="{Binding CancelCommand}" InputGestureText="Esc"/>
            </MenuItem>
            <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Edit}">
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Undo}" Command="ApplicationCommands.Undo"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Redo}" Command="ApplicationCommands.Redo"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Cut}" Command="ApplicationCommands.Cut"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Copy}" Command="ApplicationCommands.Copy"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Paste}" Command="ApplicationCommands.Paste"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_SelectAll}" Command="ApplicationCommands.SelectAll"/>
            </MenuItem>
            <MenuItem Header="{x:Static strings:Strings.Compose_Menu_View}">
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_PlainText}" x:Name="MenuModePlain"
                          InputGestureText="Ctrl+Shift+1" Click="MenuModePlain_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Markdown}" x:Name="MenuModeMarkdown"
                          InputGestureText="Ctrl+Shift+2" Click="MenuModeMarkdown_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Html}" x:Name="MenuModeHtml"
                          InputGestureText="Ctrl+Shift+3" Click="MenuModeHtml_Click"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Preview}" IsEnabled="{Binding IsPreviewAvailable}" InputGestureText="F8" Click="MenuOpenPreview_Click" AutomationProperties.Name="{x:Static strings:Strings.Compose_OpenPreview}"/>
            </MenuItem>
            <!-- The top-level Format menu is always enabled (Windows standard:
                 top-level menus are never skipped); individual items gray out
                 in Plain Text mode. Formatting works in HTML (real formatting)
                 and Markdown (inserts the equivalent syntax). -->
            <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Format}" SubmenuOpened="FormatMenu_SubmenuOpened">
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Bold}" InputGestureText="Ctrl+B"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarBold_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Italic}" InputGestureText="Ctrl+I"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarItalic_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Underline}" InputGestureText="Ctrl+U"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarUnderline_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Strikethrough}" InputGestureText="Ctrl+Shift+X"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarStrikethrough_Click"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Heading1}" InputGestureText="Ctrl+Alt+1"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarHeading1_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Heading2}" InputGestureText="Ctrl+Alt+2"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarHeading2_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Heading3}" InputGestureText="Ctrl+Alt+3"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarHeading3_Click"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_BulletList}" InputGestureText="Ctrl+Shift+L"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarBulletList_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_NumberedList}" InputGestureText="Ctrl+Shift+N"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarNumberedList_Click"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_InsertLink}" InputGestureText="Ctrl+L"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarInsertLink_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_ClearFormatting}" InputGestureText="Ctrl+Space"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarClearFormatting_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_AnnounceFormatting}" InputGestureText="Ctrl+T"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="MenuAnnounceFormatting_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_ShowFormatting}" InputGestureText="Ctrl+Shift+T"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="MenuShowFormatting_Click"/>
            </MenuItem>
            <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Tools}">
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_CheckSpelling}" InputGestureText="F7"
                          IsEnabled="{Binding IsSpellNavAvailable}"
                          Click="MenuCheckSpelling_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_NextMisspelling}" InputGestureText="Ctrl+F7"
                          IsEnabled="{Binding IsSpellNavAvailable}"
                          Click="MenuNextMisspelling_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_PreviousMisspelling}" InputGestureText="Ctrl+Shift+F7"
                          IsEnabled="{Binding IsSpellNavAvailable}"
                          Click="MenuPrevMisspelling_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_ToggleSpellingAnnouncements}" Click="MenuToggleSpelling_Click"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_AddressBook}" InputGestureText="Ctrl+Shift+B" Click="MenuAddressBook_Click"/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_CheckAddresses}" InputGestureText="Ctrl+K" Click="MenuCheckAddresses_Click"/>
                <Separator/>
                <MenuItem Header="{x:Static strings:Strings.Compose_Menu_CommandPalette}" InputGestureText="Ctrl+Shift+P" Click="MenuCommandPalette_Click"/>
            </MenuItem>
        </Menu>

    <DockPanel Margin="10"
               AllowDrop="True"
               DragOver="Window_DragOver"
               Drop="Window_Drop">

        <!-- Formatting toolbar — visible in HTML mode only (managed in code-behind) -->
        <ToolBarTray DockPanel.Dock="Top" x:Name="FormattingToolbarTray" Visibility="Collapsed"
                     Background="{DynamicResource Theme.ChromeBackground}">
            <ToolBar KeyboardNavigation.TabNavigation="Once"
                     KeyboardNavigation.DirectionalNavigation="Cycle"
                     Background="{DynamicResource Theme.ChromeBackground}"
                     Foreground="{DynamicResource Theme.TextPrimary}">
                <Button x:Name="BoldButton" Content="B" FontWeight="Bold" MinWidth="28"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_FormatName_Bold}"
                        AutomationProperties.AcceleratorKey="Ctrl+B"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_Bold}" Click="ToolbarBold_Click"/>
                <Button Content="I" FontStyle="Italic" MinWidth="28"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_FormatName_Italic}"
                        AutomationProperties.AcceleratorKey="Ctrl+I"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_Italic}" Click="ToolbarItalic_Click"/>
                <Button MinWidth="28"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_FormatName_Underline}"
                        AutomationProperties.AcceleratorKey="Ctrl+U"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_Underline}" Click="ToolbarUnderline_Click">
                    <TextBlock Text="U" TextDecorations="Underline"/>
                </Button>
                <Button MinWidth="28"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_FormatName_Strikethrough}"
                        AutomationProperties.AcceleratorKey="Ctrl+Shift+X"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_Strikethrough}" Click="ToolbarStrikethrough_Click">
                    <TextBlock Text="S" TextDecorations="Strikethrough"/>
                </Button>
                <Separator/>
                <Button Content="H1" MinWidth="28"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_FormatName_Heading1}"
                        AutomationProperties.AcceleratorKey="Ctrl+Alt+1"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_Heading1}" Click="ToolbarHeading1_Click"/>
                <Button Content="H2" MinWidth="28"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_FormatName_Heading2}"
                        AutomationProperties.AcceleratorKey="Ctrl+Alt+2"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_Heading2}" Click="ToolbarHeading2_Click"/>
                <Button Content="H3" MinWidth="28"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_FormatName_Heading3}"
                        AutomationProperties.AcceleratorKey="Ctrl+Alt+3"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_Heading3}" Click="ToolbarHeading3_Click"/>
                <Separator/>
                <Button Content="• List" MinWidth="40"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_BulletList}"
                        AutomationProperties.AcceleratorKey="Ctrl+Shift+L"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_BulletList}" Click="ToolbarBulletList_Click"/>
                <Button Content="1. List" MinWidth="40"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_NumberedList}"
                        AutomationProperties.AcceleratorKey="Ctrl+Shift+N"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_NumberedList}" Click="ToolbarNumberedList_Click"/>
                <Separator/>
                <Button Content="Link" MinWidth="40"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_InsertLink}"
                        AutomationProperties.AcceleratorKey="Ctrl+L"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_InsertLink}" Click="ToolbarInsertLink_Click"/>
                <Button Content="Clear" MinWidth="40"
                        AutomationProperties.Name="{x:Static strings:Strings.Compose_ClearFormatting}"
                        AutomationProperties.AcceleratorKey="Ctrl+Space"
                        ToolTip="{x:Static strings:Strings.Compose_Tooltip_ClearFormatting}" Click="ToolbarClearFormatting_Click"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Status / progress bar -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.Compose_CancelButton}"
                    Command="{Binding CancelCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.Compose_CancelAndCloseComposeWindow}"
                    IsCancel="True"
                    MinWidth="80" Margin="6,0,0,0"
                    TabIndex="11"/>
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.Compose_SaveDraftButton}"
                    Command="{Binding SaveDraftCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.Compose_SaveAsDraft}"
                    AutomationProperties.AcceleratorKey="Ctrl+S"
                    MinWidth="100" Margin="6,0,0,0"
                    TabIndex="10"/>
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.Compose_SaveAsTemplateButton}"
                    Command="{Binding SaveAsTemplateCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.Compose_SaveCurrentMessageAsTemplate}"
                    MinWidth="120" Margin="6,0,0,0"
                    TabIndex="9"/>
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.Compose_InsertTemplateButton}"
                    Command="{Binding InsertTemplateCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.Compose_InsertASavedTemplate}"
                    MinWidth="120" Margin="6,0,0,0"
                    TabIndex="8"/>
            <Button DockPanel.Dock="Right"
                    x:Name="SendButton"
                    Content="{x:Static strings:Strings.Compose_SendButton}"
                    Command="{Binding SendCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.Compose_SendMessage}"
                    AutomationProperties.AcceleratorKey="Alt+S"
                    IsDefault="True"
                    MinWidth="80"
                    TabIndex="7"/>
            <ComboBox DockPanel.Dock="Left"
                      x:Name="ModeSelector"
                      MinWidth="110" Margin="0,0,6,0"
                      AutomationProperties.Name="{x:Static strings:Strings.Compose_ComposeMode}"
                      TabIndex="12"
                      SelectionChanged="ModeSelector_SelectionChanged">
                <ComboBoxItem Content="{x:Static strings:Strings.Compose_Announce_ModeNamePlainText}"/>
                <ComboBoxItem Content="{x:Static strings:Strings.Compose_Announce_ModeNameMarkdown}"/>
                <ComboBoxItem Content="{x:Static strings:Strings.Compose_Announce_ModeNameHtml}"/>
            </ComboBox>
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding AutoSaveText}"
                       Foreground="{DynamicResource Theme.TextSecondary}"
                       Margin="0,0,8,0"/>
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding StatusText}"
                       AutomationProperties.Name="{x:Static strings:Strings.Compose_SendStatus}"
                       Foreground="{DynamicResource Theme.Error}"/>
        </DockPanel>

        <!-- Form fields -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- From -->
            <Label Grid.Row="0" Grid.Column="0"
                   x:Name="FromLabel"
                   Content="{x:Static strings:Strings.Compose_FromLabel}"
                   Target="{Binding ElementName=FromCombo}"
                   Padding="0" VerticalAlignment="Center" Margin="0,4"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      x:Name="FromCombo"
                      ItemsSource="{Binding SenderAccounts}"
                      SelectedItem="{Binding SenderAccount, Mode=TwoWay}"
                      DisplayMemberPath="AccountLabel"
                      AutomationProperties.Name="{x:Static strings:Strings.Compose_FromAccount}"
                      AutomationProperties.AcceleratorKey="Alt+M"
                      AutomationProperties.HelpText="{x:Static strings:Strings.Compose_ChooseWhichAccountToSendFrom}"
                      Margin="0,4" TabIndex="0"/>

            <!-- To -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       x:Name="ToLabel" Text="{x:Static strings:Strings.Compose_ToLabel}"
                       VerticalAlignment="Center" Margin="0,4"/>
            <controls:TokenizedAddressBox Grid.Row="1" Grid.Column="1"
                     x:Name="ToBox"
                     AddressText="{Binding To, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=ToLabel}"
                     AutomationProperties.HelpText="{x:Static strings:Strings.Compose_AddressBoxHelpText}"
                     Margin="0,4" TabIndex="1"/>

            <!-- Cc -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       x:Name="CcLabel" Text="{x:Static strings:Strings.Compose_CcLabel}"
                       VerticalAlignment="Center" Margin="0,4"/>
            <controls:TokenizedAddressBox Grid.Row="2" Grid.Column="1"
                     x:Name="CcBox"
                     AddressText="{Binding Cc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=CcLabel}"
                     Margin="0,4" TabIndex="2"/>

            <!-- Bcc -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       x:Name="BccLabel" Text="{x:Static strings:Strings.Compose_BccLabel}"
                       VerticalAlignment="Center" Margin="0,4"/>
            <controls:TokenizedAddressBox Grid.Row="3" Grid.Column="1"
                     x:Name="BccBox"
                     AddressText="{Binding Bcc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=BccLabel}"
                     Margin="0,4" TabIndex="3"/>

            <!-- Subject -->
            <Label Grid.Row="4" Grid.Column="0"
                   x:Name="SubjectLabel" Content="{x:Static strings:Strings.Compose_SubjectLabel}"
                   Target="{Binding ElementName=SubjectBox}"
                   Padding="0" VerticalAlignment="Center" Margin="0,4"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     x:Name="SubjectBox"
                     Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=SubjectLabel}"
                     AutomationProperties.Name="{x:Static strings:Strings.Compose_Subject}"
                     AutomationProperties.AcceleratorKey="Alt+U"
                     IsInactiveSelectionHighlightEnabled="True"
                     Margin="0,4" TabIndex="4"/>

            <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,4"/>

            <!-- Attachments -->
            <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Content="{x:Static strings:Strings.Compose_AddFilesButton}"
                    Command="{Binding AddAttachmentsCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.Compose_AddFileAttachments}"
                    AutomationProperties.AcceleratorKey="Ctrl+Shift+A"
                    HorizontalAlignment="Left"
                    Margin="0,2" TabIndex="5"/>
            <ListBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                     x:Name="AttachmentList"
                     ItemsSource="{Binding Attachments}"
                     SelectionMode="Single"
                     MaxHeight="80"
                     Margin="0,2"
                     TabIndex="6"
                     KeyboardNavigation.TabNavigation="Once"
                     KeyboardNavigation.DirectionalNavigation="Contained"
                     AutomationProperties.Name="{x:Static strings:Strings.Compose_Attachments}"
                     PreviewKeyDown="AttachmentList_PreviewKeyDown">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Attachments.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FileName, StringFormat='{}{0}'}"
                                   ToolTip="{Binding FileSizeDisplay}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static strings:Strings.Compose_Menu_Open}"
                                  Command="{Binding PlacementTarget.DataContext.OpenComposeAttachmentCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="{x:Static strings:Strings.Compose_Menu_RemoveAttachment}"
                                  Command="{Binding PlacementTarget.DataContext.RemoveAttachmentCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>

            <!-- Attachment summary: file count and total size -->
            <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding AttachmentSummaryText}"
                       FontSize="{DynamicResource Theme.FontSizeSmall}"
                       Foreground="{DynamicResource Theme.TextSecondary}"
                       VerticalAlignment="Bottom"
                       Margin="2,0,0,2">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Attachments.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Body: plain/Markdown TextBox and rich HTML editor.
                 Only one editor is visible at a time; visibility is swapped in
                 code-behind when the compose mode changes. -->
            <Grid Grid.Row="9" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         x:Name="BodyBox"
                         Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{x:Static strings:Strings.Compose_MessageBody}"
                         AutomationProperties.AcceleratorKey="Alt+Y"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         IsInactiveSelectionHighlightEnabled="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="{DynamicResource Theme.FontFamily}"
                         Margin="0,4" TabIndex="7"
                         VerticalAlignment="Stretch"
                         PreviewKeyDown="BodyBox_PreviewKeyDown"/>

                <RichTextBox Grid.Row="0"
                             x:Name="RichBodyBox"
                             Visibility="Collapsed"
                             AutomationProperties.Name="{x:Static strings:Strings.Compose_MessageBody}"
                             AutomationProperties.AcceleratorKey="Alt+Y"
                             AcceptsReturn="True" AcceptsTab="True"
                             IsInactiveSelectionHighlightEnabled="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="{DynamicResource Theme.FontFamily}"
                             Margin="0,4" TabIndex="7"
                             VerticalAlignment="Stretch"
                             TextChanged="RichBodyBox_TextChanged"/>
            </Grid>
        </Grid>

        <!-- Autocomplete popup — positioned below the active address field via code-behind -->
        <Popup x:Name="AutoCompletePopup"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="None">
            <Border BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    Background="{DynamicResource Theme.WindowBackground}">
                <ListBox x:Name="SuggestionList"
                         MaxHeight="200"
                         MinWidth="300"
                         AutomationProperties.Name="{x:Static strings:Strings.Compose_AddressSuggestions}"
                         IsTabStop="True"
                         KeyboardNavigation.TabNavigation="Cycle"
                         PreviewKeyDown="SuggestionList_PreviewKeyDown"
                         MouseLeftButtonUp="SuggestionList_MouseLeftButtonUp">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="AutomationProperties.Name" Value="{Binding Display}"/>
                            <Setter Property="Padding" Value="6,3"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding PrimaryText}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SecondaryText}"
                                           Foreground="{DynamicResource Theme.TextSecondary}"
                                           FontSize="{DynamicResource Theme.FontSizeSmall}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
    </DockPanel>
    </DockPanel>
</Window>
