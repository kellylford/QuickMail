<Window x:Class="QuickMail.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:QuickMail.Controls"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="540" Width="680"
        MinHeight="360" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Alt"  Command="{Binding SendCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveDraftCommand}"/>
        <KeyBinding Key="A" Modifiers="Ctrl+Shift" Command="{Binding AddAttachmentsCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- Menu bar. Reached with Alt or F10 (not a tab stop, per platform convention).
             Every item dispatches to the same handler or command as its keyboard
             shortcut; InputGestureText must match the registered default gesture. -->
        <Menu DockPanel.Dock="Top"
              IsTabStop="False"
              KeyboardNavigation.TabNavigation="None">
            <MenuItem Header="_File">
                <MenuItem Header="_Send" InputGestureText="Alt+S" Click="MenuSend_Click"/>
                <MenuItem Header="Save _Draft" Command="{Binding SaveDraftCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="_Insert Template…" Command="{Binding InsertTemplateCommand}"/>
                <MenuItem Header="Save as _Template" Command="{Binding SaveAsTemplateCommand}"/>
                <Separator/>
                <MenuItem Header="_Add Attachments…" Command="{Binding AddAttachmentsCommand}" InputGestureText="Ctrl+Shift+A"/>
                <Separator/>
                <MenuItem Header="_Close" Command="{Binding CancelCommand}" InputGestureText="Esc"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="ApplicationCommands.Undo"/>
                <MenuItem Header="_Redo" Command="ApplicationCommands.Redo"/>
                <Separator/>
                <MenuItem Header="Cu_t" Command="ApplicationCommands.Cut"/>
                <MenuItem Header="_Copy" Command="ApplicationCommands.Copy"/>
                <MenuItem Header="_Paste" Command="ApplicationCommands.Paste"/>
                <MenuItem Header="Select _All" Command="ApplicationCommands.SelectAll"/>
                <Separator/>
                <MenuItem Header="_Next Misspelling" InputGestureText="F7"
                          IsEnabled="{Binding IsSpellNavAvailable}"
                          Click="MenuNextMisspelling_Click"/>
                <MenuItem Header="Pre_vious Misspelling" InputGestureText="Shift+F7"
                          IsEnabled="{Binding IsSpellNavAvailable}"
                          Click="MenuPrevMisspelling_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Plain Text" x:Name="MenuModePlain"
                          InputGestureText="Ctrl+Shift+1" Click="MenuModePlain_Click"/>
                <MenuItem Header="_Markdown" x:Name="MenuModeMarkdown"
                          InputGestureText="Ctrl+Shift+2" Click="MenuModeMarkdown_Click"/>
                <MenuItem Header="_HTML" x:Name="MenuModeHtml"
                          InputGestureText="Ctrl+Shift+3" Click="MenuModeHtml_Click"/>
                <Separator/>
                <MenuItem Header="Pre_view" IsEnabled="{Binding IsPreviewAvailable}" InputGestureText="F8" Click="MenuOpenPreview_Click" AutomationProperties.Name="Open preview"/>
            </MenuItem>
            <!-- The top-level Format menu is always enabled (Windows standard:
                 top-level menus are never skipped); individual items gray out
                 in Plain Text mode. Formatting works in HTML (real formatting)
                 and Markdown (inserts the equivalent syntax). -->
            <MenuItem Header="F_ormat" SubmenuOpened="FormatMenu_SubmenuOpened">
                <MenuItem Header="_Bold" InputGestureText="Ctrl+B"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarBold_Click"/>
                <MenuItem Header="_Italic" InputGestureText="Ctrl+I"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarItalic_Click"/>
                <MenuItem Header="_Underline" InputGestureText="Ctrl+U"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarUnderline_Click"/>
                <MenuItem Header="_Strikethrough" InputGestureText="Ctrl+Shift+X"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarStrikethrough_Click"/>
                <Separator/>
                <MenuItem Header="Heading _1" InputGestureText="Ctrl+Alt+1"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarHeading1_Click"/>
                <MenuItem Header="Heading _2" InputGestureText="Ctrl+Alt+2"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarHeading2_Click"/>
                <MenuItem Header="Heading _3" InputGestureText="Ctrl+Alt+3"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarHeading3_Click"/>
                <Separator/>
                <MenuItem Header="Bu_llet List" InputGestureText="Ctrl+Shift+L"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarBulletList_Click"/>
                <MenuItem Header="_Numbered List" InputGestureText="Ctrl+Shift+N"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarNumberedList_Click"/>
                <Separator/>
                <MenuItem Header="Insert Lin_k…" InputGestureText="Ctrl+L"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarInsertLink_Click"/>
                <MenuItem Header="_Clear Formatting" InputGestureText="Ctrl+Space"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="ToolbarClearFormatting_Click"/>
                <MenuItem Header="_Announce Formatting" InputGestureText="Ctrl+T"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="MenuAnnounceFormatting_Click"/>
                <MenuItem Header="Sho_w Formatting…" InputGestureText="Ctrl+Shift+T"
                          IsEnabled="{Binding IsFormattingAvailable}" Click="MenuShowFormatting_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Address Book…" InputGestureText="Ctrl+Shift+B" Click="MenuAddressBook_Click"/>
                <MenuItem Header="Chec_k Addresses" InputGestureText="Ctrl+K" Click="MenuCheckAddresses_Click"/>
                <MenuItem Header="Toggle _Spelling Announcements" Click="MenuToggleSpelling_Click"/>
                <Separator/>
                <MenuItem Header="Command _Palette…" InputGestureText="Ctrl+Shift+P" Click="MenuCommandPalette_Click"/>
            </MenuItem>
        </Menu>

    <DockPanel Margin="10"
               AllowDrop="True"
               DragOver="Window_DragOver"
               Drop="Window_Drop">

        <!-- Formatting toolbar — visible in HTML mode only (managed in code-behind) -->
        <ToolBarTray DockPanel.Dock="Top" x:Name="FormattingToolbarTray" Visibility="Collapsed">
            <ToolBar KeyboardNavigation.TabNavigation="Once"
                     KeyboardNavigation.DirectionalNavigation="Cycle">
                <Button x:Name="BoldButton" Content="B" FontWeight="Bold" MinWidth="28"
                        AutomationProperties.Name="Bold"
                        AutomationProperties.AcceleratorKey="Ctrl+B"
                        ToolTip="Bold (Ctrl+B)" Click="ToolbarBold_Click"/>
                <Button Content="I" FontStyle="Italic" MinWidth="28"
                        AutomationProperties.Name="Italic"
                        AutomationProperties.AcceleratorKey="Ctrl+I"
                        ToolTip="Italic (Ctrl+I)" Click="ToolbarItalic_Click"/>
                <Button MinWidth="28"
                        AutomationProperties.Name="Underline"
                        AutomationProperties.AcceleratorKey="Ctrl+U"
                        ToolTip="Underline (Ctrl+U)" Click="ToolbarUnderline_Click">
                    <TextBlock Text="U" TextDecorations="Underline"/>
                </Button>
                <Button MinWidth="28"
                        AutomationProperties.Name="Strikethrough"
                        AutomationProperties.AcceleratorKey="Ctrl+Shift+X"
                        ToolTip="Strikethrough (Ctrl+Shift+X)" Click="ToolbarStrikethrough_Click">
                    <TextBlock Text="S" TextDecorations="Strikethrough"/>
                </Button>
                <Separator/>
                <Button Content="H1" MinWidth="28"
                        AutomationProperties.Name="Heading 1"
                        AutomationProperties.AcceleratorKey="Ctrl+Alt+1"
                        ToolTip="Heading 1 (Ctrl+Alt+1)" Click="ToolbarHeading1_Click"/>
                <Button Content="H2" MinWidth="28"
                        AutomationProperties.Name="Heading 2"
                        AutomationProperties.AcceleratorKey="Ctrl+Alt+2"
                        ToolTip="Heading 2 (Ctrl+Alt+2)" Click="ToolbarHeading2_Click"/>
                <Button Content="H3" MinWidth="28"
                        AutomationProperties.Name="Heading 3"
                        AutomationProperties.AcceleratorKey="Ctrl+Alt+3"
                        ToolTip="Heading 3 (Ctrl+Alt+3)" Click="ToolbarHeading3_Click"/>
                <Separator/>
                <Button Content="• List" MinWidth="40"
                        AutomationProperties.Name="Bullet list"
                        AutomationProperties.AcceleratorKey="Ctrl+Shift+L"
                        ToolTip="Bullet List (Ctrl+Shift+L)" Click="ToolbarBulletList_Click"/>
                <Button Content="1. List" MinWidth="40"
                        AutomationProperties.Name="Numbered list"
                        AutomationProperties.AcceleratorKey="Ctrl+Shift+N"
                        ToolTip="Numbered List (Ctrl+Shift+N)" Click="ToolbarNumberedList_Click"/>
                <Separator/>
                <Button Content="Link" MinWidth="40"
                        AutomationProperties.Name="Insert link"
                        AutomationProperties.AcceleratorKey="Ctrl+L"
                        ToolTip="Insert Link (Ctrl+L)" Click="ToolbarInsertLink_Click"/>
                <Button Content="Clear" MinWidth="40"
                        AutomationProperties.Name="Clear formatting"
                        AutomationProperties.AcceleratorKey="Ctrl+Space"
                        ToolTip="Clear Formatting (Ctrl+Space)" Click="ToolbarClearFormatting_Click"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Status / progress bar -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <Button DockPanel.Dock="Right"
                    Content="_Cancel"
                    Command="{Binding CancelCommand}"
                    AutomationProperties.Name="Cancel and close compose window"
                    IsCancel="True"
                    MinWidth="80" Margin="6,0,0,0"
                    TabIndex="11"/>
            <Button DockPanel.Dock="Right"
                    Content="Save Draft"
                    Command="{Binding SaveDraftCommand}"
                    AutomationProperties.Name="Save as draft"
                    AutomationProperties.AcceleratorKey="Ctrl+S"
                    MinWidth="100" Margin="6,0,0,0"
                    TabIndex="10"/>
            <Button DockPanel.Dock="Right"
                    Content="Save as Template"
                    Command="{Binding SaveAsTemplateCommand}"
                    AutomationProperties.Name="Save current message as template"
                    MinWidth="120" Margin="6,0,0,0"
                    TabIndex="9"/>
            <Button DockPanel.Dock="Right"
                    Content="Insert Template…"
                    Command="{Binding InsertTemplateCommand}"
                    AutomationProperties.Name="Insert a saved template"
                    MinWidth="120" Margin="6,0,0,0"
                    TabIndex="8"/>
            <Button DockPanel.Dock="Right"
                    x:Name="SendButton"
                    Content="Send"
                    Command="{Binding SendCommand}"
                    AutomationProperties.Name="Send message"
                    AutomationProperties.AcceleratorKey="Alt+S"
                    IsDefault="True"
                    MinWidth="80"
                    TabIndex="7"/>
            <ComboBox DockPanel.Dock="Left"
                      x:Name="ModeSelector"
                      MinWidth="110" Margin="0,0,6,0"
                      AutomationProperties.Name="Compose mode"
                      TabIndex="12"
                      SelectionChanged="ModeSelector_SelectionChanged">
                <ComboBoxItem Content="Plain Text"/>
                <ComboBoxItem Content="Markdown"/>
                <ComboBoxItem Content="HTML"/>
            </ComboBox>
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding AutoSaveText}"
                       Foreground="Gray"
                       Margin="0,0,8,0"/>
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding StatusText}"
                       AutomationProperties.Name="Send status"
                       Foreground="DarkRed"/>
        </DockPanel>

        <!-- Form fields -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- From -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Fro_m:"
                       VerticalAlignment="Center" Margin="0,4"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      x:Name="FromCombo"
                      ItemsSource="{Binding SenderAccounts}"
                      SelectedItem="{Binding SenderAccount, Mode=TwoWay}"
                      DisplayMemberPath="AccountLabel"
                      AutomationProperties.Name="From account"
                      AutomationProperties.AcceleratorKey="Alt+M"
                      AutomationProperties.HelpText="Choose which account to send from"
                      Margin="0,4" TabIndex="0"/>

            <!-- To -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       x:Name="ToLabel" Text="To:"
                       VerticalAlignment="Center" Margin="0,4"/>
            <controls:TokenizedAddressBox Grid.Row="1" Grid.Column="1"
                     x:Name="ToBox"
                     AddressText="{Binding To, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=ToLabel}"
                     AutomationProperties.HelpText="Type an address and press comma, semicolon, or Tab to add it. Arrow keys navigate between addresses. Delete removes the focused address."
                     Margin="0,4" TabIndex="1"/>

            <!-- Cc -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       x:Name="CcLabel" Text="Cc:"
                       VerticalAlignment="Center" Margin="0,4"/>
            <controls:TokenizedAddressBox Grid.Row="2" Grid.Column="1"
                     x:Name="CcBox"
                     AddressText="{Binding Cc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=CcLabel}"
                     Margin="0,4" TabIndex="2"/>

            <!-- Bcc -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       x:Name="BccLabel" Text="Bcc:"
                       VerticalAlignment="Center" Margin="0,4"/>
            <controls:TokenizedAddressBox Grid.Row="3" Grid.Column="1"
                     x:Name="BccBox"
                     AddressText="{Binding Bcc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=BccLabel}"
                     Margin="0,4" TabIndex="3"/>

            <!-- Subject -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       x:Name="SubjectLabel" Text="S_ubject:"
                       VerticalAlignment="Center" Margin="0,4"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     x:Name="SubjectBox"
                     Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.LabeledBy="{Binding ElementName=SubjectLabel}"
                     AutomationProperties.Name="Subject"
                     AutomationProperties.AcceleratorKey="Alt+U"
                     Margin="0,4" TabIndex="4"/>

            <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,4"/>

            <!-- Attachments -->
            <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Content="Add Files…"
                    Command="{Binding AddAttachmentsCommand}"
                    AutomationProperties.Name="Add file attachments"
                    AutomationProperties.AcceleratorKey="Ctrl+Shift+A"
                    HorizontalAlignment="Left"
                    Margin="0,2" TabIndex="5"/>
            <ListBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                     x:Name="AttachmentList"
                     ItemsSource="{Binding Attachments}"
                     SelectionMode="Single"
                     MaxHeight="80"
                     Margin="0,2"
                     TabIndex="6"
                     KeyboardNavigation.TabNavigation="Once"
                     KeyboardNavigation.DirectionalNavigation="Contained"
                     AutomationProperties.Name="Attachments"
                     PreviewKeyDown="AttachmentList_PreviewKeyDown">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Attachments.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FileName, StringFormat='{}{0}'}"
                                   ToolTip="{Binding FileSizeDisplay}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="_Open"
                                  Command="{Binding PlacementTarget.DataContext.OpenComposeAttachmentCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="_Remove"
                                  Command="{Binding PlacementTarget.DataContext.RemoveAttachmentCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>

            <!-- Attachment summary: file count and total size -->
            <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding AttachmentSummaryText}"
                       FontSize="11"
                       Foreground="Gray"
                       VerticalAlignment="Bottom"
                       Margin="2,0,0,2">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Attachments.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Body: plain/Markdown TextBox and rich HTML editor.
                 Only one editor is visible at a time; visibility is swapped in
                 code-behind when the compose mode changes. -->
            <Grid Grid.Row="9" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         x:Name="BodyBox"
                         Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Message body"
                         AutomationProperties.AcceleratorKey="Alt+Y"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         SpellCheck.IsEnabled="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Segoe UI"
                         Margin="0,4" TabIndex="7"
                         VerticalAlignment="Stretch"
                         PreviewKeyDown="BodyBox_PreviewKeyDown"/>

                <RichTextBox Grid.Row="0"
                             x:Name="RichBodyBox"
                             Visibility="Collapsed"
                             AutomationProperties.Name="Message body"
                             AutomationProperties.AcceleratorKey="Alt+Y"
                             AcceptsReturn="True" AcceptsTab="True"
                             SpellCheck.IsEnabled="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Segoe UI"
                             Margin="0,4" TabIndex="7"
                             VerticalAlignment="Stretch"
                             TextChanged="RichBodyBox_TextChanged"/>
            </Grid>
        </Grid>

        <!-- Autocomplete popup — positioned below the active address field via code-behind -->
        <Popup x:Name="AutoCompletePopup"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="None">
            <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                <ListBox x:Name="SuggestionList"
                         MaxHeight="200"
                         MinWidth="300"
                         AutomationProperties.Name="Address suggestions"
                         IsTabStop="True"
                         KeyboardNavigation.TabNavigation="Cycle"
                         PreviewKeyDown="SuggestionList_PreviewKeyDown"
                         MouseLeftButtonUp="SuggestionList_MouseLeftButtonUp">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="AutomationProperties.Name" Value="{Binding Display}"/>
                            <Setter Property="Padding" Value="6,3"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding PrimaryText}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SecondaryText}"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
    </DockPanel>
    </DockPanel>
</Window>
