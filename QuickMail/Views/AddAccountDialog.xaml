<Window x:Class="QuickMail.Views.AddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        mc:Ignorable="d"
        Title="{x:Static strings:Strings.AddAccount_Title}"
        Height="640" Width="420"
        MinHeight="540" MinWidth="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Backend selector — shown only when the feature gate offers more than one backend.
                     Default users (single backend) see no extra UI, identical to before. -->
                <StackPanel Visibility="{Binding ShowBackendPicker, Converter={StaticResource BoolToVisibility}}">
                    <Label x:Name="LblBackend" Content="{x:Static strings:Strings.AddAccount_AccountType}" Target="{Binding ElementName=BackendComboBox}" Padding="0" Margin="0,0,0,2"/>
                    <ComboBox x:Name="BackendComboBox"
                              ItemsSource="{Binding AvailableBackends}"
                              SelectedItem="{Binding SelectedBackend, Mode=TwoWay}"
                              SelectionChanged="BackendComboBox_SelectionChanged"
                              AutomationProperties.LabeledBy="{Binding ElementName=LblBackend}"
                              TabIndex="0"/>
                    <Separator Margin="0,12"/>
                </StackPanel>

                <TextBlock Text="{x:Static strings:Strings.AddAccount_AccountDetails}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <Label x:Name="LblAccountName" Content="{x:Static strings:Strings.AddAccount_AccountName}" Target="{Binding ElementName=AccountNameBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="AccountNameBox"
                         Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblAccountName}"
                         TabIndex="0"/>

                <Label x:Name="LblDisplayName" Content="{x:Static strings:Strings.AddAccount_DisplayName}" Target="{Binding ElementName=DisplayNameBox}" Padding="0" Margin="0,8,0,2"/>
                <TextBox x:Name="DisplayNameBox"
                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblDisplayName}"
                         TabIndex="1"/>

                <Label x:Name="LblUsername" Content="{x:Static strings:Strings.AddAccount_Username}" Target="{Binding ElementName=UsernameBox}" Padding="0" Margin="0,8,0,2"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblUsername}"
                         TabIndex="2"/>

                <!-- Authentication type — hidden for Microsoft 365 (Graph), which is always OAuth. -->
                <StackPanel Visibility="{Binding IsImapBackend, Converter={StaticResource BoolToVisibility}}">
                    <Label x:Name="LblAuthType" Content="{x:Static strings:Strings.AddAccount_Authentication}" Target="{Binding ElementName=AuthTypeCombo}" Padding="0" Margin="0,8,0,2"/>
                    <ComboBox x:Name="AuthTypeCombo"
                              SelectedIndex="{Binding AuthTypeIndex, Mode=TwoWay}"
                              AutomationProperties.LabeledBy="{Binding ElementName=LblAuthType}"
                              AutomationProperties.Name="{x:Static strings:Strings.AddAccount_AuthenticationMethod_Name}"
                              TabIndex="3">
                        <ComboBoxItem Content="{x:Static strings:Strings.AddAccount_Auth_Password}"/>
                        <ComboBoxItem Content="{x:Static strings:Strings.AddAccount_Auth_MicrosoftOAuth2}"/>
                        <ComboBoxItem Content="{x:Static strings:Strings.AddAccount_Auth_GoogleOAuth}" Visibility="{Binding ShowGoogleAuthOption, Converter={StaticResource BoolToVisibility}}"/>
                    </ComboBox>
                </StackPanel>

                <!-- Password panel (hidden for OAuth2) -->
                <StackPanel Visibility="{Binding IsPasswordAuth, Converter={StaticResource BoolToVisibility}}">
                    <Label x:Name="LblPassword" Content="{x:Static strings:Strings.AddAccount_Password}" Target="{Binding ElementName=PasswordBox}" Padding="0" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="PasswordBox"
                                 AutomationProperties.LabeledBy="{Binding ElementName=LblPassword}"
                                 AutomationProperties.HelpText="{x:Static strings:Strings.AddAccount_Password_HelpText}"
                                 TabIndex="5"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                    <!-- iCloud app-specific password hint -->
                    <Border Visibility="{Binding IsICloudAccount, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource Theme.WarningBackground}"
                            BorderBrush="{DynamicResource Theme.Warning}"
                            BorderThickness="1"
                            Padding="8,6"
                            Margin="0,6,0,0">
                        <TextBlock TextWrapping="Wrap"
                                   AutomationProperties.Name="{x:Static strings:Strings.AddAccount_ICloudHint_Name}">
                            <Run FontWeight="SemiBold" Text="{x:Static strings:Strings.AddAccount_ICloudHint_Run1}"/>
                            <Run Text="{x:Static strings:Strings.AddAccount_ICloudHint_Run2}"/>
                            <Run FontWeight="SemiBold" Text="{x:Static strings:Strings.AddAccount_ICloudHint_Run3}"/>
                            <Run Text="{x:Static strings:Strings.AddAccount_ICloudHint_Run4}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Microsoft OAuth2 sign-in panel -->
                <StackPanel Visibility="{Binding IsOAuth2, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,4,0,0">
                    <Button Content="{x:Static strings:Strings.AddAccount_SignInMicrosoft}"
                            Command="{Binding SignInMicrosoftCommand}"
                            AutomationProperties.Name="{x:Static strings:Strings.AddAccount_SignInMicrosoft_Name}"
                            HorizontalAlignment="Left" MinWidth="200" TabIndex="5"/>
                </StackPanel>

                <!-- Google OAuth sign-in panel -->
                <StackPanel Visibility="{Binding IsGoogleOAuth, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,4,0,0">
                    <Button Content="{x:Static strings:Strings.AddAccount_SignInGoogle}"
                            Command="{Binding SignInGoogleCommand}"
                            AutomationProperties.Name="{x:Static strings:Strings.AddAccount_SignInGoogle_Name}"
                            HorizontalAlignment="Left" MinWidth="200" TabIndex="5"/>
                </StackPanel>

                <!-- IMAP + SMTP server settings — collapsed for Microsoft Graph accounts,
                     which authenticate via OAuth and need no host configuration. -->
                <StackPanel Visibility="{Binding IsImapBackend, Converter={StaticResource BoolToVisibility}}">
                <Separator Margin="0,12"/>

                <TextBlock Text="{x:Static strings:Strings.AddAccount_IncomingMail}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <Label x:Name="LblImapHost" Content="{x:Static strings:Strings.AddAccount_ImapHost}" Target="{Binding ElementName=ImapHostBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="ImapHostBox"
                         Text="{Binding ImapHost, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblImapHost}"
                         TabIndex="4"/>

                <Label x:Name="LblImapPort" Content="{x:Static strings:Strings.AddAccount_ImapPort}" Target="{Binding ElementName=ImapPortBox}" Padding="0" Margin="0,6,0,2"/>
                <TextBox x:Name="ImapPortBox"
                         Text="{Binding ImapPort, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblImapPort}"
                         TabIndex="4"/>

                <CheckBox Content="{x:Static strings:Strings.AddAccount_ImapUseSsl}"
                          IsChecked="{Binding ImapUseSsl}"
                          AutomationProperties.Name="{x:Static strings:Strings.AddAccount_ImapUseSsl_Name}"
                          Margin="0,6" TabIndex="5"/>

                <CheckBox Content="{x:Static strings:Strings.AddAccount_ImapAcceptInvalidCert}"
                          IsChecked="{Binding ImapAcceptInvalidCert}"
                          AutomationProperties.Name="{x:Static strings:Strings.AddAccount_ImapAcceptInvalidCert_Name}"
                          Margin="0,0,0,6" TabIndex="6"/>

                <Separator Margin="0,6"/>

                <TextBlock Text="{x:Static strings:Strings.AddAccount_OutgoingMail}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <Label x:Name="LblSmtpHost" Content="{x:Static strings:Strings.AddAccount_SmtpHost}" Target="{Binding ElementName=SmtpHostBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="SmtpHostBox"
                         Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblSmtpHost}"
                         TabIndex="7"/>

                <Label x:Name="LblSmtpPort" Content="{x:Static strings:Strings.AddAccount_SmtpPort}" Target="{Binding ElementName=SmtpPortBox}" Padding="0" Margin="0,6,0,2"/>
                <TextBox x:Name="SmtpPortBox"
                         Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblSmtpPort}"
                         TabIndex="8"/>

                <CheckBox Content="{x:Static strings:Strings.AddAccount_SmtpUseSsl}"
                          IsChecked="{Binding SmtpUseSsl}"
                          AutomationProperties.Name="{x:Static strings:Strings.AddAccount_SmtpUseSsl_Name}"
                          Margin="0,6" TabIndex="9"/>

                <CheckBox Content="{x:Static strings:Strings.AddAccount_SmtpAcceptInvalidCert}"
                          IsChecked="{Binding SmtpAcceptInvalidCert}"
                          AutomationProperties.Name="{x:Static strings:Strings.AddAccount_SmtpAcceptInvalidCert_Name}"
                          Margin="0,0,0,6" TabIndex="10"/>
                </StackPanel>

                <Separator Margin="0,6"/>

                <!-- Signature -->
                <TextBlock Text="{x:Static strings:Strings.AddAccount_EmailSignature}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Label x:Name="LblSignature" Content="{x:Static strings:Strings.AddAccount_Signature}" Target="{Binding ElementName=SignatureBox}" Padding="0" Margin="0,4,0,2"/>
                <TextBox x:Name="SignatureBox"
                         Text="{Binding Signature, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.LabeledBy="{Binding ElementName=LblSignature}"
                         AutomationProperties.HelpText="{x:Static strings:Strings.AddAccount_Signature_HelpText}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         VerticalScrollBarVisibility="Auto"
                         TabIndex="11"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Status text -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusText}"
                   AutomationProperties.Name="{x:Static strings:Strings.AddAccount_Status_Name}"
                   Foreground="{DynamicResource Theme.Accent}"
                   Margin="0,8,0,4"
                   TextWrapping="Wrap"/>

        <!-- Buttons -->
        <DockPanel Grid.Row="2">
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.Common_Cancel}"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    AutomationProperties.Name="{x:Static strings:Strings.AddAccount_Cancel_Name}"
                    MinWidth="80" Margin="6,0,0,0"/>
            <Button x:Name="TestConnectionButton"
                    DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.AddAccount_TestConnection}"
                    Command="{Binding TestConnectionCommand}"
                    AutomationProperties.Name="{x:Static strings:Strings.AddAccount_TestConnection_Name}"
                    MinWidth="120" Margin="6,0,0,0"/>
            <Button DockPanel.Dock="Right"
                    Content="{x:Static strings:Strings.AddAccount_AddAccount}"
                    IsDefault="True"
                    Click="AddButton_Click"
                    AutomationProperties.Name="{x:Static strings:Strings.AddAccount_AddAccount_Name}"
                    MinWidth="100"/>
            <TextBlock/>
        </DockPanel>
    </Grid>
</Window>
