<Window x:Class="QuickMail.Views.FolderPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:QuickMail.Models"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        Title="{x:Static strings:Strings.FolderPicker_Title}"
        Height="420" Width="420"
        MinHeight="220" MinWidth="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <DockPanel Margin="10">

        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,8"
                 TextChanged="SearchBox_TextChanged"
                 PreviewKeyDown="SearchBox_PreviewKeyDown"
                 AutomationProperties.Name="{x:Static strings:Strings.FolderPicker_FolderSearch}"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="OpenButton"
                    Content="{x:Static strings:Strings.FolderPicker_OpenButton}"
                    IsDefault="True"
                    MinWidth="75"
                    Margin="0,0,6,0"
                    Click="OpenButton_Click"
                    AutomationProperties.Name="{x:Static strings:Strings.FolderPicker_OpenSelectedFolder}"/>
            <Button Content="{x:Static strings:Strings.FolderPicker_CancelButton}"
                    IsCancel="True"
                    MinWidth="75"
                    AutomationProperties.Name="{x:Static strings:Strings.Common_Cancel}"/>
        </StackPanel>

        <ListBox x:Name="FolderListBox"
                 AutomationProperties.Name="{x:Static strings:Strings.FolderPicker_Folders}"
                 BorderThickness="1"
                 KeyboardNavigation.TabNavigation="Once"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True"
                 PreviewKeyDown="FolderListBox_PreviewKeyDown"
                 MouseDoubleClick="FolderListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="3,2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding FolderPath}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding AccountName}"
                                   FontSize="{DynamicResource Theme.FontSizeSmall}"
                                   Opacity="0.75"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AccountName}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <TreeView x:Name="FolderTreeView"
                  Visibility="Collapsed"
                  AutomationProperties.Name="{x:Static strings:Strings.FolderPicker_Folders}"
                  BorderThickness="1"
                  KeyboardNavigation.TabNavigation="Once"
                  PreviewKeyDown="FolderTreeView_PreviewKeyDown"
                  MouseDoubleClick="FolderTreeView_MouseDoubleClick">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type models:FolderTreeNode}"
                                          ItemsSource="{Binding Children}">
                    <TextBlock TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding Label}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                    <Setter Property="IsExpanded"                Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}"/>
                    <Setter Property="AutomationProperties.ItemStatus" Value="{Binding ItemStatusLabel}"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

    </DockPanel>
</Window>
