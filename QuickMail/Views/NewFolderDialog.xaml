<Window x:Class="QuickMail.Views.NewFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Folder"
        Height="160" Width="360"
        MinHeight="140" MinWidth="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="OkButton"
                    Content="_OK"
                    IsDefault="True"
                    MinWidth="75"
                    Margin="0,0,6,0"
                    Click="OkButton_Click"
                    AutomationProperties.Name="Create folder"/>
            <Button Content="_Cancel"
                    IsCancel="True"
                    MinWidth="75"
                    AutomationProperties.Name="Cancel"/>
        </StackPanel>

        <StackPanel>
            <TextBlock x:Name="ParentLabel"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,6"
                       Focusable="False"/>
            <TextBox x:Name="FolderNameBox"
                     AutomationProperties.Name="Folder name"
                     AutomationProperties.HelpText="Enter a name for the new folder"
                     MaxLength="255"
                     PreviewKeyDown="FolderNameBox_PreviewKeyDown"/>
        </StackPanel>

    </DockPanel>
</Window>
