<Window x:Class="QuickMail.Views.PropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QuickMail.Views"
        Title="{Binding Title}"
        Width="520" Height="480"
        MinWidth="360" MinHeight="280"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    </Window.Resources>

    <DockPanel>

        <!-- Bottom button row -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="8">
            <Button Content="Copy _all"
                    TabIndex="90"
                    MinWidth="90"
                    Margin="0,0,6,0"
                    Command="{Binding CopyAllCommand}"
                    AutomationProperties.Name="Copy all properties"/>
            <Button Content="_Close"
                    TabIndex="91"
                    MinWidth="75"
                    IsCancel="True"
                    AutomationProperties.Name="Close"/>
        </StackPanel>

        <!-- Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8" KeyboardNavigation.TabNavigation="Local">

                <!-- Single properties list; section header rows are interleaved as focusable items -->
                <ListView x:Name="PropertiesList"
                          ItemsSource="{Binding Rows}"
                          SelectionMode="Extended"
                          KeyboardNavigation.TabNavigation="Once"
                          AutomationProperties.Name="{Binding Title}"
                          KeyDown="PropertyList_KeyDown">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Field" Width="140"
                                DisplayMemberBinding="{Binding Label}"/>
                            <GridViewColumn Header="Value" Width="300"
                                DisplayMemberBinding="{Binding Value}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="AutomationProperties.Name"
                                Value="{Binding Converter={x:Static local:PropertyItemNameConverter.Instance}}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Raw headers expander (message context only, hidden when RawHeaders is null) -->
                <Expander Header="Raw headers"
                          Visibility="{Binding RawHeaders, Converter={StaticResource NullToCollapsed}}"
                          Margin="0,4,0,0"
                          AutomationProperties.Name="Raw headers">
                    <TextBox Text="{Binding RawHeaders, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MaxHeight="200"
                             FontFamily="Consolas"
                             AutomationProperties.Name="Raw message headers"/>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
