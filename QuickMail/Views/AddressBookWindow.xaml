<Window x:Class="QuickMail.Views.AddressBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickMail.Views"
        mc:Ignorable="d"
        Title="Address Book"
        Height="520" Width="700"
        MinHeight="380" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        AutomationProperties.Name="Address Book"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="InsertRow" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasInsertActions}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <TabControl x:Name="MainTabs"
                    KeyboardNavigation.TabNavigation="Local"
                    TabIndex="0">
            <TabItem Header="Contacts"
                     AutomationProperties.Name="Contacts"
                     KeyboardNavigation.TabNavigation="Local">
                <DockPanel Margin="0,6,0,0">
                    <!-- Search -->
                    <TextBox DockPanel.Dock="Top"
                             x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Search contacts"
                             Margin="0,0,0,6"
                             TabIndex="0"/>

                    <!-- Insert into message — visible only when opened from Compose (Ctrl+Shift+B) -->
                    <StackPanel DockPanel.Dock="Top"
                                Style="{StaticResource InsertRow}"
                                Orientation="Horizontal"
                                Margin="0,0,0,6">
                        <TextBlock Text="Add selected contact to:"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="_To"
                                Command="{Binding AddToToCommand}"
                                IsEnabled="{Binding HasSelectedContact}"
                                AutomationProperties.Name="Add to To field"
                                MinWidth="50" Margin="0,0,4,0" TabIndex="1"/>
                        <Button Content="_Cc"
                                Command="{Binding AddToCcCommand}"
                                IsEnabled="{Binding HasSelectedContact}"
                                AutomationProperties.Name="Add to Cc field"
                                MinWidth="50" Margin="0,0,4,0" TabIndex="2"/>
                        <Button Content="_Bcc"
                                Command="{Binding AddToBccCommand}"
                                IsEnabled="{Binding HasSelectedContact}"
                                AutomationProperties.Name="Add to Bcc field"
                                MinWidth="50" TabIndex="3"/>
                    </StackPanel>

                    <!-- Contact detail fields + action buttons -->
                    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Name + Email (always visible, readonly unless editing) -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   x:Name="ContactNameLabel"
                                   Content="_Name:"
                                   Target="{Binding ElementName=ContactNameBox}"
                                   VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     x:Name="ContactNameBox"
                                     Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.LabeledBy="{Binding ElementName=ContactNameLabel}"
                                     AutomationProperties.Name="Contact name"
                                     PreviewKeyDown="ContactFieldBox_PreviewKeyDown"
                                     Margin="4,0" TabIndex="5"/>

                            <Label Grid.Column="2"
                                   x:Name="ContactEmailLabel"
                                   Content="_Email:"
                                   Target="{Binding ElementName=ContactEmailBox}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                            <TextBox Grid.Column="3"
                                     x:Name="ContactEmailBox"
                                     Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.LabeledBy="{Binding ElementName=ContactEmailLabel}"
                                     AutomationProperties.Name="Contact email"
                                     PreviewKeyDown="ContactFieldBox_PreviewKeyDown"
                                     Margin="4,0" TabIndex="6"/>
                        </Grid>

                        <!-- Row 1: Action buttons (two sets, toggled by IsEditingContact) -->
                        <!-- Display mode buttons -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    Visibility="{Binding IsContactReadOnly, Converter={StaticResource BoolToVis}}"
                                    Margin="0,4,0,0">
                            <Button Content="_Add"
                                    Command="{Binding BeginAddContactCommand}"
                                    AutomationProperties.Name="Add contact"
                                    MinWidth="60" Margin="0,0,4,0" TabIndex="7"/>
                            <Button Content="_Edit"
                                    Command="{Binding BeginEditContactCommand}"
                                    AutomationProperties.Name="Edit contact"
                                    IsEnabled="{Binding CanEditContact}"
                                    MinWidth="60" Margin="0,0,4,0" TabIndex="8"/>
                            <Button Content="_Delete"
                                    Click="DeleteButton_Click"
                                    AutomationProperties.Name="Delete selected contact"
                                    IsEnabled="{Binding CanDeleteContact}"
                                    MinWidth="60" Margin="0,0,4,0" TabIndex="9"/>
                            <Border Margin="0,0,4,0"/>
                            <Button Content="Close"
                                    AutomationProperties.Name="Close address book"
                                    MinWidth="60" TabIndex="10"
                                    Click="Close_Click"/>
                        </StackPanel>

                        <!-- Edit mode buttons -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    Visibility="{Binding IsEditingContact, Converter={StaticResource BoolToVis}}"
                                    Margin="0,4,0,0">
                            <Button Content="_Save"
                                    Command="{Binding SaveContactCommand}"
                                    AutomationProperties.Name="Save contact"
                                    MinWidth="60" Margin="0,0,4,0" TabIndex="7"/>
                            <Button Content="Cancel"
                                    Command="{Binding CancelEditCommand}"
                                    AutomationProperties.Name="Cancel edit"
                                    MinWidth="60" Margin="0,0,4,0" TabIndex="8"/>
                            <Border Margin="0,0,4,0"/>
                            <Button Content="Close"
                                    AutomationProperties.Name="Close address book"
                                    MinWidth="60" TabIndex="9"
                                    Click="Close_Click"/>
                        </StackPanel>

                        <!-- Row 2: Error message (shown only when non-empty) -->
                        <TextBlock Grid.Row="2" Text="{Binding ContactError}"
                                   Foreground="Red" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContactError}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Contact list -->
                    <ListView x:Name="ContactList"
                              ItemsSource="{Binding FilteredContacts}"
                              SelectedItem="{Binding SelectedContact}"
                              AutomationProperties.Name="Contacts"
                              TabIndex="4"
                              KeyboardNavigation.TabNavigation="Once"
                              KeyboardNavigation.DirectionalNavigation="Contained"
                              PreviewKeyDown="ContactList_PreviewKeyDown"
                              ContextMenuOpening="ContactList_ContextMenuOpening">
                        <ListView.ContextMenu>
                            <ContextMenu AutomationProperties.Name="Add to group"/>
                        </ListView.ContextMenu>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            AutomationProperties.Name="{Binding Display}">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="  &lt;"/>
                                    <TextBlock Text="{Binding EmailAddress}" Foreground="#666"/>
                                    <TextBlock Text="&gt;"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </TabItem>

            <TabItem Header="Groups"
                     AutomationProperties.Name="Groups"
                     KeyboardNavigation.TabNavigation="Local">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="180"/>
                        <ColumnDefinition Width="3*" MinWidth="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: groups list -->
                    <DockPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Groups"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,3"
                                   AutomationProperties.Name="Groups header"/>
                        <ListView x:Name="GroupsList"
                                  ItemsSource="{Binding Groups}"
                                  SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                  AutomationProperties.Name="Groups"
                                  TabIndex="20"
                                  KeyboardNavigation.TabNavigation="Once"
                                  PreviewKeyDown="GroupsList_PreviewKeyDown">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                AutomationProperties.Name="{Binding Display}">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="  "/>
                                        <TextBlock Text="{Binding Display, Converter={x:Static local:GroupSubtitleConverter.Instance}}"
                                                   Foreground="#666"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>

                    <!-- Right: members of selected group + insert buttons -->
                    <DockPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding SelectedGroup.Display, StringFormat='Members of {0}'}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,3"
                                   AutomationProperties.Name="Group member list header"/>
                        <StackPanel DockPanel.Dock="Top"
                                    Style="{StaticResource InsertRow}"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,4">
                            <TextBlock Text="Insert all into:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Button Content="_To"
                                    Command="{Binding AddGroupToToCommand}"
                                    IsEnabled="{Binding HasSelectedGroup}"
                                    AutomationProperties.Name="Add all group members to To"
                                    MinWidth="48" Margin="0,0,3,0"/>
                            <Button Content="_Cc"
                                    Command="{Binding AddGroupToCcCommand}"
                                    IsEnabled="{Binding HasSelectedGroup}"
                                    AutomationProperties.Name="Add all group members to Cc"
                                    MinWidth="48" Margin="0,0,3,0"/>
                            <Button Content="_Bcc"
                                    Command="{Binding AddGroupToBccCommand}"
                                    IsEnabled="{Binding HasSelectedGroup}"
                                    AutomationProperties.Name="Add all group members to Bcc"
                                    MinWidth="48"/>
                        </StackPanel>
                        <ListView x:Name="GroupMembersList"
                                  ItemsSource="{Binding SelectedGroupMembers}"
                                  AutomationProperties.Name="Group members"
                                  TabIndex="21"
                                  KeyboardNavigation.TabNavigation="Once"
                                  PreviewKeyDown="GroupMembersList_PreviewKeyDown">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                AutomationProperties.Name="{Binding Display}">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="  &lt;"/>
                                        <TextBlock Text="{Binding EmailAddress}" Foreground="#666"/>
                                        <TextBlock Text="&gt;"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>

                    <!-- Bottom action area: name entry (hidden until needed) + buttons.
                         Buttons are direct Grid children (not wrapped) so the BFS tab-order
                         scan finds them before the insert-row buttons in the right pane. -->
                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 0: Name entry — Collapsed until New or Rename is activated -->
                        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6"
                                   x:Name="GroupNameEntryPanel"
                                   Visibility="Collapsed" Margin="0,0,0,6">
                            <Label DockPanel.Dock="Left"
                                   x:Name="GroupNameLabel"
                                   Content="Name:"
                                   Target="{Binding ElementName=NewGroupNameBox}"
                                   VerticalAlignment="Center"/>
                            <TextBox x:Name="NewGroupNameBox"
                                     Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="Group name"
                                     IsTabStop="False"
                                     Margin="4,0"
                                     PreviewKeyDown="NewGroupNameBox_PreviewKeyDown"/>
                        </DockPanel>

                        <!-- Row 1: buttons as direct Grid children (Col 4 is the * spacer that
                             pushes Close to the right without wrapping in a DockPanel) -->
                        <Button Grid.Row="1" Grid.Column="0"
                                x:Name="NewGroupButton"
                                Content="_New"
                                AutomationProperties.Name="New group"
                                MinWidth="60" Margin="0,0,4,0" TabIndex="23"
                                Click="NewGroupButton_Click"/>
                        <Button Grid.Row="1" Grid.Column="1"
                                x:Name="RenameGroupButton"
                                Content="_Rename"
                                IsEnabled="{Binding HasSelectedGroup}"
                                AutomationProperties.Name="Rename selected group"
                                MinWidth="60" Margin="0,0,4,0" TabIndex="24"
                                Click="RenameGroupButton_Click"/>
                        <Button Grid.Row="1" Grid.Column="2"
                                Content="_Delete"
                                Command="{Binding DeleteGroupCommand}"
                                IsEnabled="{Binding HasSelectedGroup}"
                                AutomationProperties.Name="Delete selected group"
                                MinWidth="60" Margin="0,0,4,0" TabIndex="25"/>
                        <Button Grid.Row="1" Grid.Column="3"
                                x:Name="ManageGroupsButton"
                                Content="_Manage…"
                                AutomationProperties.Name="Open Group Manager"
                                MinWidth="70" Margin="0,0,4,0" TabIndex="26"
                                Click="ManageGroupsButton_Click"/>
                        <!-- Col 4 (*) is empty — acts as spacer to right-align Close -->
                        <Button Grid.Row="1" Grid.Column="5"
                                Content="Close"
                                IsCancel="True"
                                AutomationProperties.Name="Close address book"
                                MinWidth="60" TabIndex="27"
                                Click="Close_Click"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
