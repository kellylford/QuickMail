<Window x:Class="QuickMail.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:strings="clr-namespace:QuickMail.Resources"
        Title="{x:Static strings:Strings.About_Title}"
        Height="200" Width="380"
        MinHeight="180" MinWidth="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.WindowBackground}"
        Foreground="{DynamicResource Theme.TextPrimary}"
        FontFamily="{DynamicResource Theme.FontFamily}"
        FontSize="{DynamicResource Theme.FontSizeBase}">

    <DockPanel Margin="20">

        <Button DockPanel.Dock="Bottom"
                Content="{x:Static strings:Strings.About_Close}"
                IsCancel="True"
                MinWidth="75"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                AutomationProperties.Name="{x:Static strings:Strings.About_CloseButtonName}"/>

        <StackPanel>
            <TextBlock Text="{x:Static strings:Strings.About_AppName}"
                       FontSize="{DynamicResource Theme.FontSizeHeader}"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>
            <TextBlock x:Name="VersionText"
                       Margin="0,0,0,12"/>
            <TextBlock>
                <Hyperlink x:Name="LicenseLink"
                           NavigateUri="https://github.com/kellylford/QuickMail/blob/main/LICENSE"
                           RequestNavigate="LicenseLink_RequestNavigate"
                           AutomationProperties.Name="{x:Static strings:Strings.About_ViewLicenseOnGitHub}">
                    <Run Text="{x:Static strings:Strings.About_MitLicense}"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>

    </DockPanel>
</Window>
