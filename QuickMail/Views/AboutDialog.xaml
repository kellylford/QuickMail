<Window x:Class="QuickMail.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About QuickMail"
        Height="200" Width="380"
        MinHeight="180" MinWidth="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="20">

        <Button DockPanel.Dock="Bottom"
                Content="_Close"
                IsCancel="True"
                MinWidth="75"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                AutomationProperties.Name="Close"/>

        <StackPanel>
            <TextBlock Text="QuickMail"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>
            <TextBlock x:Name="VersionText"
                       Margin="0,0,0,12"/>
            <TextBlock>
                <Hyperlink x:Name="LicenseLink"
                           NavigateUri="https://github.com/kellylford/QuickMail/blob/main/LICENSE"
                           RequestNavigate="LicenseLink_RequestNavigate"
                           AutomationProperties.Name="View MIT License on GitHub">
                    MIT License
                </Hyperlink>
            </TextBlock>
        </StackPanel>

    </DockPanel>
</Window>
